{%- capture productHandleContentForQuerystring -%}{{ content_for_header }}{%- endcapture -%}
{%- assign productHandlePageUrl = productHandleContentForQuerystring
  | split: '"pageurl":"'
  | last
  | split: '"'
  | first
  | split: '.myshopify.com'
  | last
  | replace: '\/', '/'
  | replace: '%20', ' '
  | replace: '\u0026', '&'
-%}
{%- assign productHandlePageQueryStringReplace = productHandlePageUrl
  | replace: request.path, ''
  | replace: request.host, ''
-%}
{%- assign productHandlePageQueryString = productHandlePageQueryStringReplace | split: '?' | last -%}
{%- assign productHandlePageQueryArray = productHandlePageQueryString | split: '&' -%}

{% assign productHandleParams = '' %}
{% assign productShapeParams = '' %}
{% assign productMetalParams = '' %}
{% assign productCaratParams = '' %}
{% assign productSkuParams = '' %}

{% assign marketing_banner_video_1 = collection.metafields.collection.marketing_banner_video_1.value %}
{% assign marketing_banner_video_1_mobile = collection.metafields.collection.marketing_banner_video_1_mobile.value %}
{% assign marketing_banner_1_headline = collection.metafields.collection.marketing_banner_1_headline.value %}
{% assign marketing_banner_1_link_text = collection.metafields.collection.marketing_banner_1_link_text.value %}
{% assign marketing_banner_1_link = collection.metafields.collection.marketing_banner_1_link.value %}
{%- assign marketing_banner_1_text_color = collection.metafields.collection.marketing_banner_1_text_color -%}
{% assign marketing_banner_video_2 = collection.metafields.collection.marketing_banner_video_2.value %}
{% assign marketing_banner_video_2_mobile = collection.metafields.custom.marketing_banner_video_2_mobile.value %}
{% assign marketing_banner_2_headline = collection.metafields.collection.marketing_banner_2_headline.value %}
{% assign marketing_banner_2_link_text = collection.metafields.collection.marketing_banner_2_link_text.value %}
{% assign marketing_banner_2_link = collection.metafields.collection.marketing_banner_2_link.value %}
{%- assign marketing_banner_2_text_color = collection.metafields.collection.marketing_banner_2_text_color -%}

{% if productHandlePageQueryArray != blank %}
  {% for param in productHandlePageQueryArray %}
    {%- if param contains 'handle' -%}
      {% assign productHandleParams = param | split: '=' | last %}
    {%- endif -%}
  {% endfor %}

  {% for param in productHandlePageQueryArray %}
    {%- if param contains 'shape' -%}
      {% assign productShapeParams = param | split: '=' | last %}
    {%- endif -%}
  {% endfor %}

  {% for param in productHandlePageQueryArray %}
    {%- if param contains 'carat' -%}
      {% assign productCaratParams = param | split: '=' | last %}
    {%- endif -%}
  {% endfor %}

  {% for param in productHandlePageQueryArray %}
    {%- if param contains 'sku' -%}
      {% assign productSkuParams = param | split: '=' | last %}
    {%- endif -%}
  {% endfor %}

  {% for param in productHandlePageQueryArray %}
    {%- if param contains 'filter.p.m.custom.metal' -%}
      {% assign productMetalParams = param | split: '=' | last | strip %}
      {% assign productMetalParams = productMetalParams | replace: '+', '%20' | strip %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if related_products == true %}
  {% assign hover_enabled = block.settings.show_related_products_title_on_hover %}
{% else %}
  {% assign hover_enabled = settings.thumbnail_hover_enabled %}
{% endif %}

{% if type == 'block' %}
  {% assign object = block %}
{% else %}
  {% assign object = section %}
{% endif %}

{% assign secondaryImage = product.media[1] %}

{% assign collection_handles = product.collections | map: 'handle' %}
{% if product.featured_media.preview_image.alt contains 'youtube' or image.alt contains 'vimeo' %}
  {% assign alt_text = product.title %}
{% else %}
  {% assign alt_text = product.featured_media.preview_image.alt %}
{% endif %}
{% if alt_text == blank %}
  {% assign alt_text = product.title %} 
{% endif %}

{% if type == 'block' %}
  {% assign image_crop = block.settings.image_crop %}
{% else %}
  {% assign image_crop = section.settings.image_crop %}
{% endif %}

{% if align_height == true %}
  {% style %}
    .shopify-model-viewer-ui model-viewer {
      --progress-bar-height: 2px;
      --progress-bar-color: {{ settings.regular_color }};
    }
  {% endstyle %}
{% endif %}
{% if template == 'collection.filter-tab' %}
  {% assign canonical_urll = canonical_url | split: '/' | last %}
  {% if product.url contains '?' %}
    {% comment %} {% assign canonical_url_append = '&material=lab-diamond&stone-handle=' %}
    {% assign canonical_url_gem_append = '&material=lab-gemstone&stone-handle=' %} {% endcomment %}
     {% assign canonical_url_append = '&dyo=diamond_journey&material=lab-diamond&stone-handle=' %}
    {% assign canonical_url_gem_append = '&material=lab-gemstone&stone-handle=' %}
  {% else %}
    {% comment %} {% assign canonical_url_append = '?material=lab-diamond&stone-handle=' %}
    {% assign canonical_url_gem_append = '?material=lab-gemstone&stone-handle=' %} {% endcomment %}
     {% assign canonical_url_append = '?dyo=diamond_journey&material=lab-diamond&stone-handle=' %}
    {% assign canonical_url_gem_append = '?material=lab-gemstone&stone-handle=' %}
  {% endif %}

  {% assign selected_product_handles = all_products[productHandleParams] %}
  {% if productCaratParams != blank %}
    {% comment %} API-driven page: diamond carat comes from the request param, not a Shopify product. {% endcomment %}
    {% assign carat_first = productCaratParams | plus: 0 %}
  {% else %}
    {% assign caret_tag = selected_product_handles.tags | where: 'carat_' %}
    {% assign carat_first = caret_tag | split: 'carat_' | last | remove: '[' %}
    {% assign carat_first = carat_first | remove: '"]' | plus: 0 %}
  {% endif %}

  {% assign gem_type_tag = selected_product_handles.tags | where: 'gem_type_' %}
  {% assign gem_type_first = gem_type_tag | split: 'gem_type_' | last | replace: '_', '%20' %}

  {% assign flag = 0 %}
  {% assign max_carat_weight = product.metafields.attributes.max_carat_weight | divided_by: 100.0 %}
  {% assign min_carat_weight = product.metafields.attributes.min_carat_weight | divided_by: 100.0 %}

  {% if max_carat_weight != blank and min_carat_weight != blank %}
    {% if carat_first >= min_carat_weight and carat_first <= max_carat_weight %}
      {% assign flag = 1 %}
    {% else %}
      {% assign flag = 0 %}
    {% endif %}
  {% else %}
    {% assign flag = 0 %}
  {% endif %}

  {% if selected_product_handles.type == 'Lab Created Diamond' or productCaratParams != blank %}
    {% assign append_url = canonical_url_append | append: productHandleParams %}
    {% assign prod_url = product.url | append: append_url %}
  {% elsif selected_product_handles.type == 'Lab Created Gemstone'
    or selected_product_handles.type == 'Diamond Hybrid'
  %}
    {% assign append_url_gem = canonical_url_gem_append | append: productHandleParams %}
    {% assign prod_url = product.url | append: append_url_gem %}
  {% else %}
    {% comment %} {% assign prod_url = product.url | within: collection %} {% endcomment %}
    {% assign prod_url =  product.url %}
  {% endif %}
{% else %}

{% endif %}

{% assign firstbannerimage = true %}
{% if marketing_banner_video_1 or marketing_banner_video_1_mobile %}
  {% assign firstbannerimage = false %}
{% comment %} {%- if index == 3 or index == 2-%} {% endcomment %}
 {%- if  index == 3-%}

  
  
  {% unless marketing_banner_video_1 %}
    {% assign marketing_banner_video_1 = marketing_banner_video_1_mobile  %}
  {% endunless %}  
  {% unless marketing_banner_video_1_mobile %}
    {% assign marketing_banner_video_1_mobile = marketing_banner_video_1  %}
  {% endunless %}  
<div
  class="
    {% if flag == 0 %}gray-disabled{% else %}active-filter{% endif %}
    one-whole
    medium-down--one-whole
    {% if mobile_products_per_row == '1' %}
      small-down--one-whole
    {% else %}
      small-down--one-whole
    {% endif %}
    column
    {% if settings.enable_quickshop %}
      quick-shop--true
      quick-shop--closed
      product-{{ product.id }} js-product_section
    {% endif %}
    thumbnail
    product__thumbnail
    product__grid-item
    thumbnail__hover-overlay--{{ hover_enabled }}
    plp-banner-section
    plp-promotion-banner-{% if index == 3 or index == 9 %}desktop{% else %}medium{% endif %}
  "
  {% if section.settings.pagination_type != 'basic_pagination' %}
    data-load-more--grid-item
  {% endif %}
>

  <div class="list-bnrbox">
    {% if marketing_banner_video_1.media_type == 'video' %}
      {% if marketing_banner_1_link %} 
        <a href="{{ marketing_banner_1_link }}" class="video-fullview v-desktopview"  aria-label="Shop Now">
      {% else %}
        <div class="video-fullview v-desktopview">
      {% endif %}

      {%- for source in marketing_banner_video_1.sources -%}
        {%- if source.mime_type contains 'video' -%}
          {%- assign video_url = source.url -%}
          {%- assign poster_url = video_url | append:'&speedsize=w_1080,pstr' -%}
          {%- assign mime_type = source.mime_type -%}
        {%- endif -%}
      {%- endfor -%}

      <video class="plp-banner-video-desktop" preload="auto"  autoplay muted loop playsinline poster="{{ poster_url | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}">
        <source src="{{ video_url | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}" type="{{ mime_type }}">  
        Your browser does not support the video tag.  
      </video>
      {% if marketing_banner_1_link %} 
      </a>
       {% else %}
       </div>
      {% endif %}
        {% if marketing_banner_1_link %} 
      <a href="{{ marketing_banner_1_link }}" class="video-fullview v-mobileview"   aria-label="Shop Now">
       {% else %}
           <div class="video-fullview v-mobileview">
      {% endif %}
      {%- for source in marketing_banner_video_1_mobile.sources -%}
        {%- if source.mime_type contains 'video' -%}
          {%- assign video_url_1_mobile = source.url -%}
          {%- assign poster_url_1_mobile = video_url_1_mobile | append:'&speedsize=w_1080,pstr' -%}
          {%- assign mime_type_1_mobile = source.mime_type -%}
        {%- endif -%}
      {%- endfor -%}
        <video class="plp-banner-video-mobile" autoplay muted loop playsinline poster="{{ poster_url_1_mobile | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}">
          <source data-src="{{ video_url_1_mobile | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}" src="" type="{{ mime_type_1_mobile }}">
          Your browser does not support the video tag.
        </video>
       {% if marketing_banner_1_link %} 
      </a>
        {% else %}
       </div>
      {% endif %}
      {% else %}
      {% if marketing_banner_1_link!=blank %} 
        <a href="{{ marketing_banner_1_link }}" class="list-bnrimg" style="background: url('{{ marketing_banner_video_1 | image_url}}');" role="img" aria-label="{{ marketing_banner_video_1.alt | escape }}">
      {% else %}  
           <div class="list-bnrimg" style="background: url('{{ settings.speedsize_url_pfx_https -}}{{ marketing_banner_video_1|image_url}} }}');" role="img" aria-label="{{ marketing_banner_video_1.alt | escape }}">
      {%- endif -%}
        <img class="plp-banner-img" src="{{ settings.speedsize_url_pfx_https -}}{{ marketing_banner_video_1_mobile|image_url}}" alt="{{ marketing_banner_video_1_mobile.alt | escape }}"  width="1250px"   height="1250px" loading="lazy">
         {% if marketing_banner_1_link!=blank %} 
        </a>
         {% else %}  
        </div>
    {%- endif -%}
    {%- endif -%}
    {% if marketing_banner_1_headline!=blank or marketing_banner_1_link_text!=blank or marketing_banner_1_link!=blank %}
    <div class="list-bnrbox-text{% if marketing_banner_1_text_color == 'Black' %} list-bnrbox-text-black{% endif %}" aria-hidden="false">
      {% if marketing_banner_1_headline %}
      <h2 id="banner-heading-1">{{ marketing_banner_1_headline }}</h2>
       {% endif %}
       {% if marketing_banner_1_link!=blank and marketing_banner_1_link_text!=blank %} 
        <a href="{{ marketing_banner_1_link }}" class="line-hover" aria-label="{{marketing_banner_1_link_text}}">{{marketing_banner_1_link_text}}</a>
      {% elsif marketing_banner_1_link_text!=blank %}
         <div class="sub-text" aria-label="{{marketing_banner_1_link_text}}">{{marketing_banner_1_link_text}}</div>
      {% endif %}
    </div>
   {% endif %}

  </div>
</div>
{%- endif -%}
{%- endif -%}

{% if marketing_banner_video_2 or marketing_banner_video_2_mobile  %}
