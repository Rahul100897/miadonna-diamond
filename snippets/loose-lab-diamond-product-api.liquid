<div
  class="
    product_section
    js-product_section
    container
    is-justify-space-between
    has-padding-bottom
    has-no-side-gutter
    {% if product_images_position == 'right' %}
      is-flex-row-reverse
    {% endif %}
  "
>

  <div
    class="
      product__images
      three-fifths
      column
      large-down--one-whole
    "
  >
  <div class="pg-container new-loose-diamond" style="display: flex; flex-wrap: wrap; gap: 8px;">

    <div class="image__container pg-row-two pg-row-single" id="product-image--section" style="flex: 1 1 240px; min-width: 0;">
      <a id="diamond-image-link" href="" class="product-gallery__link" data-fancybox="product-gallery">
        <div class="pg-cell">
          <img
            id="diamond-main-image"
            src=""
            alt=""
            style="width: 100%; height: auto; display: block;"
          >
        </div>
      </a>
    </div>

    <div id="product-video--section" class="pg-row-two" style="display: none; flex: 1 1 240px; min-width: 0;">
      <div id="product-vimeo_video" class="pg-cell is-video">
        <div class="lazyframe canvas-video pg-cell" data-ratio="9:16">
          <iframe
            id="diamond-video-frame"
            frameborder="0"
            title="360 degree product view"
            loading="lazy"
            scrolling="no"
            src=""
            style="width: 100%; aspect-ratio: 9 / 16; border: 0; display: block;"
          ></iframe>
        </div>
      </div>
    </div>

  </div>
  </div>

  <div
    class="
      product__information
      has-product-sticker
      two-fifths
      column
      large-down--one-whole
    "
  >
    <div class="sku-review">
      <div class="block--sku">
          <div class="order-ship-date">
              <p class="order-ship-text">SKU:</p>
              <p class="order-ship-date order-ship-sku" id="diamond-sku"></p>
          </div>
      </div>
    </div>
    <h1 class="product_name title" id="diamond-product-title"></h1>
    {% render 'loose-diamond-setting-tab-api' %}
    <div class="product-additional-information">
      <setting-tabs class="setting-tabs-wrapper">
        <div class="pdp-accordion">
          <div class="sub_footer-faq-item one-whole is-open">
            <button class="sub_footer-accordion-title">
              <span>Diamond Information</span>
              <span class="icon icon-plus" data-icon="plus">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
                  <title>Plus</title>
                  <g id="plus"><path d="M95,48H52V5a2,2,0,0,0-4,0V48H5a2,2,0,0,0,0,4H48V95a2,2,0,0,0,4,0V52H95a2,2,0,0,0,0-4Z"></path></g>
                </svg>
              </span>
            </button>
            <div class="sub_footer-accordion-content">
              <div class="products__specs-wrapper">
                <div class="products__specs">
                  <div id="diamond-specifications" class="products__specs-list"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </setting-tabs>
    </div>
    {% comment %}
      Shipping/Material tab content retired here to match the live theme
      (loose-lab-diamond-product.liquid), which superseded the old 3-tab
      Product Details/Shipping/Material UI with the single "Diamond
      Information" accordion above.
    {% endcomment %}

  </div>
</div>
<script>
  if (document.getElementsByClassName('md-button--add-to-cart')?.length > 0) {
    let mdButtonAddToCartElements = document.getElementsByClassName('md-button--add-to-cart');
    mdButtonAddToCartElements = Array.prototype.slice.call(mdButtonAddToCartElements);
    for (let i = 0; i < mdButtonAddToCartElements.length; i++) {
      mdButtonAddToCartElements[i].addEventListener('click', async function() {
        let variantId = this.dataset.variant;

        this.innerHTML = '<span class="text">Processing...</span>';
        this.disabled = true;

        let properties = {};
        if (this.dataset?.productType?.length > 0) {
          properties['Material'] = this.dataset?.productType;
        }
        if (this.dataset?.optionShape?.length > 0) {
          properties['shape'] = this.dataset?.optionShape+' Cut';
        }
        if (this.dataset?.optionCut?.length > 0) {
          properties['cut'] = this.dataset?.optionCut;
        }
        if (this.dataset?.optionCarat?.length > 0) {
          properties['carat'] = this.dataset?.optionCarat+'ct';
        }
        if (this.dataset?.optionColor?.length > 0) {
          properties['color'] = this.dataset?.optionColor;
        }
        if (this.dataset?.optionClarity?.length > 0) {
          properties['clarity'] = this.dataset?.optionClarity;
        }
        if (this.dataset?.optionLab?.length > 0) {
          properties['lab'] = this.dataset?.optionLab;
        }
        if (this.dataset?.optionCertNumber?.length > 0) {
          properties['Cert Number'] = this.dataset?.optionCertNumber;
        }
        if (this.dataset?.optionSku?.length > 0) {
          properties['sku'] = this.dataset?.optionSku;
        }
        if (this.dataset?.productVendor?.length > 0) {
          properties['_vendor_name'] = this.dataset?.productVendor;
        }
        if(document.getElementById('lab-diamond-ship-date') && document.getElementById('lab-diamond-ship-date').innerHTML != ''){
          properties['Estimate Ship Date'] = document.getElementById('lab-diamond-ship-date').innerHTML;
        }
        // Create the Shopify product/variant for this diamond via the API, then add it to cart
        variantId = await createDiamondProductSetting(this.dataset.optionSku || '', this.dataset.optionHandle || '');
        if (!variantId) { this.innerHTML = '<span class="text">Add to bag</span>'; this.disabled = false; return; }
        await mdButtonAddToCart(this, variantId, 1, properties);
      });
    }
  }

  async function createDiamondProductSetting(sku, handle) {
    // Creates the Shopify product/variant for an API diamond and returns its variant id.
    try {
      const res = await fetch('http://localhost/qd-app/shopify/create-product-by-sku', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic ' + btoa('admin:123456') },
        body: JSON.stringify({ sku: sku, handle: handle })
      });
      const result = await res.json();
      // variant_id is returned at the top level for both "created" and "updated"
      return result.variant_id || result?.product?.variants?.[0]?.id || result?.product?.product?.variants?.[0]?.id || '';
    } catch (e) {
      console.log('create-product-by-sku failed', e);
      return '';
    }
  }
  async function mdButtonAddToCart(_this, variant_id, quantity = "1", properties = {}) {
    function buildForm() {
      var fd = new FormData();
      fd.append("id", variant_id);
      fd.append("quantity", quantity);
      Object.entries(properties).forEach(entry => {
        const [key, value] = entry;
        fd.append("properties[" + key + "]", value);
      });
      return fd;
    }

    // A just-created product can take a moment to be addable on the storefront
    // (the variant isn't indexed the instant it's created), which returns a 422
    // "Cannot find variant". Retry a few times so the add is reliable, and only
    // open the cart drawer once it actually succeeds.
    let added = false;
    for (let attempt = 0; attempt < 4; attempt++) {
      let rawResponse = await fetch("/cart/add.js", { method: "POST", body: buildForm() });
      if (rawResponse.ok) { added = true; break; }
      let err = await rawResponse.json().catch(() => ({}));
      console.log('[purchase-without-setting] /cart/add.js attempt ' + (attempt + 1) + ' failed', rawResponse.status, err);
      await new Promise(function (r) { setTimeout(r, 2000); });
    }

    if (!added) {
      alert('Sorry, we could not add this diamond right now. Please try again.');
      _this.innerHTML = '<span class="text">Add to bag</span>';
      _this.disabled = false;
      return;
    }

    await freeProductAddToCart();
    open_group_cart_drawer();

    _this.innerHTML = '<span class="text">Add to bag</span>';
    _this.disabled = false;
  }

  if (document.getElementsByClassName('open-cert-popup-pdp')?.length > 0) {
      let openCertPopupPDPElements = document.getElementsByClassName('open-cert-popup-pdp');
      openCertPopupPDPElements = Array.prototype.slice.call(openCertPopupPDPElements);
      for (let i = 0; i < openCertPopupPDPElements.length; i++) {
        openCertPopupPDPElements[i].addEventListener('click', function(event) {
            event.stopPropagation();
            event.preventDefault();
            var save_cert_data = this.dataset.certUrl;
            window.open(save_cert_data, '_blank').focus();

            /*
            // var save_cert_num_replace_data = this.dataset.certNumReplace;
            // var save_cert_num_data = this.dataset.certNum;
            // var save_cert_data = save_cert_data.replace(save_cert_num_replace_data,save_cert_num_data);
            var save_cert_data_arr = save_cert_data.split('.');
            var ext = save_cert_data_arr.pop().toLowerCase();

            var myCertFrame = document.getElementById('myCertFrame');
            var myCertImg = document.getElementById('myCertImg');

            myCertFrame.style.display = 'none';
            myCertImg.style.display = 'none';
            if (save_cert_data !== '') {
                if (ext === 'pdf') {
                    // myCertFrame.src = 'https://docs.google.com/gview?url=' + save_cert_data + '&embedded=true';
                    myCertFrame.src = save_cert_data;
                    myCertFrame.style.display = 'block';
                    document.getElementById('certificate-popup').style.display = 'block';
                } else if (ext === 'jpg' || ext === 'jpeg' || ext === 'png') {
                    myCertImg.src = save_cert_data;
                    myCertImg.style.display = 'block';
                    document.getElementById('certificate-popup').style.display = 'block';
                } else {
                    myCertFrame.src = save_cert_data;
                    myCertFrame.style.display = 'block';
                    document.getElementById('certificate-popup').style.display = 'block';
                }
            }
            document.querySelector('html').classList.add('certi-overflow-hidden');
            closeCertPopup();*/
        });
      }
  }

  function closeCertPopup(){
    if (document.getElementsByClassName('vdb-lb-close-cert-popup')) {
      const vdbLBCloseCertPopupElement =  document.getElementsByClassName('vdb-lb-close-cert-popup');
      for (let i = 0; i < vdbLBCloseCertPopupElement.length; i++) {
        vdbLBCloseCertPopupElement[i].addEventListener('click', function() {
          const myCertFrame = document.getElementById('myCertFrame');
          const myCertImg = document.getElementById('myCertImg');

          myCertFrame.style.display = 'none';
          myCertImg.style.display = 'none';

          myCertImg.src = '';
          myCertFrame.src = '';
          document.getElementById('certificate-popup').style.display = 'none';
          document.querySelector('html').classList.remove('certi-overflow-hidden');
        });
      }
    }
  }

  document.addEventListener("DOMContentLoaded", async function () { 
    // Legacy frontend.php "fetch_product_details_by_id" call removed —
    // cert_url now comes from the qd-app detail API (item.cert_url).
  });

  document.addEventListener('keydown', function(event) {
      if (event.code === 'Escape') {
          document.querySelector('.vdb-lb-close-cert-popup').click();
      }
  });

  if(document.getElementById('more-details-stone-pdp')){
    document.getElementById('more-details-stone-pdp').addEventListener("click", function (e) {
      e.preventDefault();
      const isMobile = window.innerWidth <= 768;
      const targetId = isMobile ? 'product-details-2-content' : 'product-details-content';
      const target = document.getElementById(targetId);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  }
</script>




{% comment %} <div class="settings-header">
  <div class="heading heading-carat">CARAT</div>
  <div class="heading heading-cut">CUT</div>
  <div class="heading heading-color">COLOR</div>
  <div class="heading heading-clarity">CLARITY</div>
  <div class="heading heading-certificate">CERTIFICATE</div>
</div>

<div class="settings-values" id="diamond-main-specs">
  <div class="value">-</div>
  <div class="value">-</div>
  <div class="value">-</div>
  <div class="value">-</div>
  <div class="value">-</div>
</div>

<div id="diamond-specifications">
  <p>Loading specifications...</p>
</div> {% endcomment %}

<script>
document.addEventListener('DOMContentLoaded', async () => {

    const urlParams = new URLSearchParams(window.location.search);
    
    if (urlParams.has('sku')) {
      // 2. Target your hidden section
      const breadcrumbContent = document.getElementById('diamond-product-breadcrumb');
      
      if (breadcrumbContent) {
        // 3. Make it visible instantly
        breadcrumbContent.style.display = 'block'; 
      }
    }


    const params = new URLSearchParams(
        window.location.search
    );

    const sku = params.get('sku');

    if (!sku) {
        console.error('SKU missing in URL');
        return;
    }
    console.log('loading API', sku);

    const username = 'admin';
    const password = '123456';

    const apiUrl = `http://localhost/qd-app/items/${sku}`;

    const specsWrapper = document.getElementById(
        'diamond-specifications'
    );

    try {

        const response = await fetch(apiUrl, {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Basic ' + btoa(`${username}:${password}`)
            }
        });

        const result = await response.json();

        console.log('Diamond API Result:', result);

        if (
            !result ||
            result.status !== 'success' ||
            !result.data
        ) {

            if (specsWrapper) {
              specsWrapper.innerHTML = `<p>No specifications found.</p>`;
            }
            return;

        }

        const item = result.data;
        // Expose the FULL spec set on the "Add to Bag" button so the
        // cart line carries every attribute (was only sku/handle -> only ~2 props).
        // Mirrors the collection/drawer add (lab-created-diamonds.js initAddToCartButton).
        document.querySelectorAll('.md-button--add-to-cart').forEach(function (b) {
          b.dataset.optionSku = item.shopify_sku || '';
          b.dataset.optionHandle = item.shopify_handle || '';
          b.dataset.productType = 'Lab Grown Diamond';      // -> Material
          b.dataset.optionShape = item.shape || '';          // handler appends " Cut"
          b.dataset.optionCut = item.cut || '';
          b.dataset.optionCarat = item.carat || '';          // handler appends "ct"
          b.dataset.optionColor = item.color || '';
          b.dataset.optionClarity = item.clarity || '';
          b.dataset.optionLab = item.lab || '';
          b.dataset.optionCertNumber = item.cert_num || '';
          b.dataset.productVendor = item.shopify_product_vendor || '';
        });
        console.log('Diamond title:', item.title);

      /*
      |--------------------------------------------------------------------------
      | Update Ring Product URLs
      |--------------------------------------------------------------------------
      */

      const updateRingLinks = () => {

          const links = document.querySelectorAll(
              '.collection-matrix a[id$="-image-url"]'
          );

          if (!links.length) { return false; }

          links.forEach(link => {

              try {

                  console.log(
                      'Original Href:',
                      link.href
                  );

                  const match = link.href.match(
                      /(https:\/\/www\.miadonna\.com\/products\/[^?&]+)/
                  );

                  if (!match) {
                      return;
                  }

                  const baseUrl = match[1];

                  const updatedUrl =
                      `${baseUrl}` +
                      `?material=lab-diamond` +
                      `&solid_metal=${encodeURIComponent(
                          '14K White Gold'
                      )}` +
                      `&shape=${encodeURIComponent(
                          (item.shape || '') + ' Cut'
                      )}` +
                      `&stone-carat=${encodeURIComponent(
                          item.carat || ''
                      )}` +
                      `&quality=${encodeURIComponent(
                          item.clarity || ''
                      )}` +
                      `&stone-handle=${encodeURIComponent(
                          item.shopify_handle || ''
                      )}` +
                      `&stone-sku=${encodeURIComponent(
                          item.shopify_sku || ''
                      )}`;

                  link.href = updatedUrl;

                  console.log(
                      'Updated URL:',
                      updatedUrl
                  );

              } catch (error) {

                  console.error(
                      'Unable to update URL',
                      error
                  );

              }

          });

          return true;

      };

      // Ring products load asynchronously; retry until their links exist (up to ~20s)
      // instead of guessing with a fixed 5s delay.
      let ringLinkTries = 0;
      const ringLinkTimer = setInterval(() => {
          if (updateRingLinks() || ++ringLinkTries > 40) {
              clearInterval(ringLinkTimer);
          }
      }, 500);

        /*
        |--------------------------------------------------------------------------
        | Main Header Data
        |--------------------------------------------------------------------------
        */
       const carat = item.carat || '-';

        const cut = item.cut
            ? item.cut.toUpperCase()
            : '-';

        const color = item.color
            ? item.color.toUpperCase()
            : '-';

        const clarity = item.clarity
            ? item.clarity.toUpperCase()
            : '-';

        const dimensions = item.measurements ? `${item.measurements} MM` : '-';

        let certificateHtml = '-';

        if ( item.cert_num && item.cert_url ) {
            certificateHtml = ` <a href="${item.cert_url}" target="_blank" rel="noopener"> #${item.cert_num} </a>`;
        } else if (item.cert_num) {
            certificateHtml = `#${item.cert_num}`;
        }

        // Icon-card specs grid (loose-diamond-setting-tab-api.liquid) — each card's
        // value is a standalone placeholder span, populated individually so the
        // surrounding icon/badge/label markup (ported verbatim from the live theme)
        // never has to be rebuilt in JS.
        const specGridValues = {
            'diamond-spec-carat': carat,
            'diamond-spec-color': color,
            'diamond-spec-clarity': clarity,
            'diamond-spec-cut': cut,
            'diamond-spec-dimensions': dimensions,
        };
        Object.keys(specGridValues).forEach(function (id) {
            const el = document.getElementById(id);
            if (el) { el.textContent = specGridValues[id]; }
        });
        const certificateSpecEl = document.getElementById('diamond-spec-certificate');
        if (certificateSpecEl) { certificateSpecEl.innerHTML = certificateHtml; }

        /*
        |--------------------------------------------------------------------------
        | Settings Data
        |--------------------------------------------------------------------------
        */
        const specs = [
            {
                label: 'Carat',
                value: item.carat
            },
            {
                label: 'Shape',
                value: item.shape
            },
            {
                label: 'Cut',
                value: item.cut
            },
            {
                label: 'Color',
                value: item.color
            },
            {
                label: 'Clarity',
                value: item.clarity
            },
            {
                label: 'Sustainability',
                value: item.sustainability
            },
            {
                label: 'Certificate',
                value: item.cert_num,
                certUrl: item.cert_url
            },
            {
                label: 'SKU',
                value: item.shopify_sku
            },
            {
                label: 'Depth',
                value: item.depth
            },
            {
                label: 'Polish',
                value: item.polish
            },
            {
                label: 'Symmetry',
                value: item.symmetry
            },
            {
                label: 'Fluorescence',
                value: item.fluor
            },
            {
                label: 'Length/Width Ratio',
                value: item.l_w_ratio
            },
            {
                label: 'Measurements',
                value: item.measurements
            },
            {
                label: 'Table',
                value: item.table
            },
            {
                label: 'Lab',
                value: item.lab
            }
        ];

        // specsWrapper is #diamond-specifications, the .products__specs-list div
        // inside the "Diamond Information" accordion (loose-lab-diamond-product-api
        // .liquid) — matches the live theme's post-redesign accordion markup
        // (loose-lab-diamond-product.liquid), not the old products__specs-list <ul>.
        let html = '';

        specs.forEach(spec => {

            if (
                spec.value === null ||
                spec.value === undefined ||
                spec.value === ''
            ) {
                return;
            }

            if (
                spec.label === 'Certificate' &&
                spec.certUrl
            ) {

                html += `
                    <div class="style-accordion pdp-accordion-common">
                        <span class="accordion-data-label">${spec.label}:</span>
                        <span class="accordion-data-value">
                            <a
                                href="${spec.certUrl}"
                                target="_blank"
                                rel="noopener"
                            >
                                #${spec.value}
                            </a>
                        </span>
                    </div>
                `;

            } else {

                html += `
                    <div class="style-accordion pdp-accordion-common">
                        <span class="accordion-data-label">${spec.label}:</span>
                        <span class="accordion-data-value">${spec.value}</span>
                    </div>
                `;
            }

        });

        specsWrapper.innerHTML = html;


       // Single SKU Replace

        const skuElement = document.getElementById('diamond-sku');
        const diamondProducTtitle = document.getElementById('diamond-product-title');
        const diamondProducTprice = document.getElementById('diamond-price');

        const videoSection = document.getElementById('product-video--section');

        const image = document.getElementById('diamond-main-image');
        const imageLink = document.getElementById('diamond-image-link');

        const videoFrame = document.getElementById('diamond-video-frame');

      console.log('item', item);

      const imageUrl = item.image_url || '';
      const videoUrl = item.video_url || '';

      console.log('imageUrl', imageUrl);
      console.log('videoUrl', videoUrl);


        if (skuElement) {
          skuElement.innerHTML = `${item.shopify_sku || '-'}`;
        }
        if (diamondProducTtitle) {
          diamondProducTtitle.innerHTML = `${item.title || '-'}`;
        }
        if (diamondProducTprice) {
          const priceNum = parseFloat(item.price);
          // #diamond-price sits inside <span class="price">{{ cart.currency.symbol }} …>,
          // so the currency symbol is ALREADY rendered by the markup — don't prepend
          // another "$" here (that caused the doubled "$ $17,500.00").
          diamondProducTprice.innerHTML = isNaN(priceNum)
            ? '-'
            : priceNum.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        // Same convention: #diamond-add-to-bag-price sits after a Liquid-rendered
        // {{ cart.currency.symbol }}, so only the number goes here.
        const diamondAddToBagPrice = document.getElementById('diamond-add-to-bag-price');
        if (diamondAddToBagPrice) {
          const priceNum = parseFloat(item.price);
          diamondAddToBagPrice.textContent = isNaN(priceNum)
            ? '-'
            : priceNum.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

         /*
          |--------------------------------------------------------------------------
          | Gallery: still photo + 360 viewer shown as stacked cells (matching the
          | live theme's .pg-container gallery for a real product's media), not as
          | tabs — QD only ever gives one image_url + one video_url, so there's no
          | multi-image library to switch between.
          |--------------------------------------------------------------------------
          */
          if (imageUrl) {

              if (image) {
                  image.src = imageUrl;
                  image.alt = item.title || '';
              }

              if (imageLink) {
                  imageLink.href = imageUrl;
              }

          }

          if (videoUrl) {

              if (videoFrame) {
                  videoFrame.src = videoUrl;
              }

              if (videoSection) {
                  videoSection.style.display = '';
              }

          }

      } catch (error) {

        console.error(
            'Diamond API Error:',
            error
        );

        specsWrapper.innerHTML = `
            <p>Unable to load specifications.</p>
        `;
    }

});
</script>