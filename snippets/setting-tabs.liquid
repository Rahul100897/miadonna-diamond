<style>
    .product-settings-loader {
        position: absolute;
        width: 100%;
        height: auto;
        top: 50%;
        right: 0;
        opacity: 0.5;
        display: flex;
        z-index: 100;
        background: #fff;
        justify-content: center;
        transform: translateY(-50%);
        /* padding-bottom: 100%; */
        transform: none;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
    }
    .product-settings-loader div {
        box-sizing: border-box;
        display: block;
        position: absolute;
        width: 44px;
        height: 44px;
        margin: 4px;
        border: 4px solid #7c7979;
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        animation: product-settings-loader 1.2s cubic-bezier(0.5, 0, 0.5, 1) infinite;
        border-color: #7c7979 transparent transparent transparent;
    }
    @media screen and (max-width: 575px) {
        .product-settings-loader {
            padding-top: 0rem;
        }
    }
    .product-settings-loader div:nth-child(1) {
        animation-delay: -0.45s;
    }
    .product-settings-loader div:nth-child(2) {
        animation-delay: -0.3s;
    }
    .product-settings-loader div:nth-child(3) {
        animation-delay: -0.15s;
    }
    @keyframes product-settings-loader {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }
    .product-settings-loader.product-settings-loader-video {
        align-items: center;
        background: #f8f8f8;
        left: 0%;
        opacity:1;
    }

    /* Disabled wrapper */
    .setting-value-inputs.option--disabled {
        opacity: 0.5;
        pointer-events: none;   /* Makes everything inside unclickable */
        cursor: not-allowed;
        position: relative;
    }

    /* Target label inside */
    .setting-value-inputs.option--disabled .input_label {
        cursor: not-allowed;
    }

    /* Line-through effect */
    .setting-value-inputs.option--disabled .input_label::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 10%;
        width: 80%;
        height: 1px;
        background-color: #999;
        transform: translateY(-50%) rotate(-0deg);
    }

    /* Optional: grayscale */
    .setting-value-inputs.option--disabled {
        filter: grayscale(100%);
    }
</style>
