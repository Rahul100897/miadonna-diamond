                            <div class="range-slider range-target">
                              <div class="range-base">
                                <tc-range-slider
                                  id="slider_depth_mia_mobile"
                                  min="{{ block.settings.main_title_depth_min }}"
                                  max="{{ block.settings.main_title_depth_max }}"
                                  value1="{{ depthMinParams }}"
                                  value2="{{ depthMaxParams }}"
                                  step="0.01"
                                  moving-tooltip="false"
                                  moving-tooltip-distance-to-pointer="-30"
                                  moving-tooltip-bg="transparent"
                                  moving-tooltip-text-color="#3c3737"
                                  moving-tooltip-width="70"
                                  moving-tooltip-height="20"
                                  mousewheel-disabled="true"
                                  pointer-bg="#000000"
                                  pointer-bg-hover="#000000"
                                  pointer-bg-focus="#000000"
                                  pointer-border="1px solid #000000"
                                  pointer-border-hover="1px solid #000000"
                                  pointer-border-focus="1px solid #000000"
                                  slider-bg="#D8D5DC"
                                  slider-bg-fill="#000000"
                                  slider-width="100%"
                                  slider-height="8px"
                                  moving-tooltip-units="%"
                                  generate-labels="false"
                                  pointer1-width="20px"
                                  pointer1-height="20px"
                                  pointer2-width="20px"
