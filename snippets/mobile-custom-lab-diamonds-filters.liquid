                            function handleTableInput() {

                                let minVal = parseFloat(minTableBox.value.replace(/[^0-9.]/g, ''));
                                let maxVal = parseFloat(maxTableBox.value.replace(/[^0-9.]/g, ''));

                                if (isNaN(minVal)) minVal = minTableValue;
                                if (isNaN(maxVal)) maxVal = maxTableValue;

                                // Clamp to allowed range
                                minVal = Math.max(minTableValue, Math.min(minVal, maxTableValue));
                                maxVal = Math.max(minTableValue, Math.min(maxVal, maxTableValue));

                                // Ensure min ≤ max
                                if (minVal > maxVal) minVal = maxVal;
                                if (maxVal < minVal) maxVal = minVal;

                                // Update slider values
