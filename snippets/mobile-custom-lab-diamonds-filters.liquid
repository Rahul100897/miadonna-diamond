                        <script>
                        document.addEventListener('DOMContentLoaded', function() {

                            const tableSlider = document.getElementById('slider_table_mia_mobile');
                            const minTableBox = document.getElementById('mintableValue');
                            const maxTableBox = document.getElementById('maxtableValue');

                            // Define min/max allowed values
                            const minTableValue = parseFloat(tableSlider.min);
                            const maxTableValue = parseFloat(tableSlider.max);

                            // Format number + "%"
                            function formatPercent(num) {
                                return parseFloat(num) + '%';
                            }

                            // Update textboxes from slider values
                            function updateTableValues() {
                                minTableBox.value = formatPercent(tableSlider.value1);
                                maxTableBox.value = formatPercent(tableSlider.value2);
                            }

                            // Initial load
                            updateTableValues();

                            // Slider → textbox
