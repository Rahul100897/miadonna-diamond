                    <script>
                                document.addEventListener('DOMContentLoaded', function() {
                                const slider = document.getElementById('slider_carat_mia_mobile');
                                const minBox = document.getElementById('minValue');
                                const maxBox = document.getElementById('maxValue');

                                // Define your min/max allowed values
                                const minCaratValue = parseFloat(slider.min); // minimum allowed
                                const maxCaratValue = parseFloat(slider.max); // maximum allowed

                                // Format number + " ct"
                                function formatCT(num) {
                                    return parseFloat(num).toFixed(2) + ' ct';
                                }

                                // Update textboxes from slider values
                                function updateValues() {
                                    minBox.value = formatCT(slider.value1);
                                    maxBox.value = formatCT(slider.value2);
                                }

                                // Initial load
                                updateValues();

                                // Slider → textbox
                                slider.addEventListener('change', updateValues);

                                // Validate input
                                function handleInput() {
                                    let minVal = parseFloat(minBox.value.replace(/[^0-9.]/g, ''));
                                    let maxVal = parseFloat(maxBox.value.replace(/[^0-9.]/g, ''));

                                    // Fallback to min/max if invalid
                                    if (isNaN(minVal)) minVal = minCaratValue;
                                    if (isNaN(maxVal)) maxVal = maxCaratValue;

                                    // Clamp to allowed range
                                    minVal = Math.max(minCaratValue, Math.min(minVal, maxCaratValue));
                                    maxVal = Math.max(minCaratValue, Math.min(maxVal, maxCaratValue));

                                    // Ensure minBox ≤ maxBox
                                    if (minVal > maxVal) minVal = maxVal;
                                    if (maxVal < minVal) maxVal = minVal;

                                    // Update slider values
                                    slider.value1 = minVal;
                                    slider.value2 = maxVal;

                                    // Update textboxes with ct
                                    minBox.value = formatCT(minVal);
                                    maxBox.value = formatCT(maxVal);
                                }

                                // Event listeners for minBox and maxBox
                                [minBox, maxBox].forEach(box => {
                                    // Only allow numbers while typing
                                    box.addEventListener('input', function() {
                                        this.value = this.value.replace(/[^0-9.]/g, '');
                                    });
                                    box.addEventListener('change', handleInput);
                                    box.addEventListener('blur', handleInput);
                                });

                            });
                    </script>  
