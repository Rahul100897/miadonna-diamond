                        <script>
                          document.addEventListener('DOMContentLoaded', function() {

                          const priceSlider = document.getElementById('slider_price_mia_mobile');
                          const minPriceBox = document.getElementById('minPrice');
                          const maxPriceBox = document.getElementById('maxPrice');

                          // Price min/max
                          const minPriceAllowed = Math.round(priceSlider.min);
                          const maxPriceAllowed = Math.round(priceSlider.max);

                          // Format price with $
                          function formatPrice(num) {
                              return '$'+Math.round(num).toLocaleString('en-US');
                          }

                          // Update textboxes from slider
                          function updatePriceBoxes() {
                              minPriceBox.value = formatPrice(priceSlider.value1 || minPriceAllowed);
                              maxPriceBox.value = formatPrice(priceSlider.value2 || maxPriceAllowed);
                          }

                          // Initial load
                          updatePriceBoxes();

                          // Slider → textbox
                          priceSlider.addEventListener('change', updatePriceBoxes);

                          // Validate input
                          function handlePriceInput() {
                              let minVal = Math.round(minPriceBox.value.replace(/[^0-9]/g, ''));
                              let maxVal = Math.round(maxPriceBox.value.replace(/[^0-9]/g, ''));

                              if (isNaN(minVal)) minVal = minPriceAllowed;
                              if (isNaN(maxVal)) maxVal = maxPriceAllowed;

                              // Clamp to allowed range
                              minVal = Math.max(minPriceAllowed, Math.min(minVal, maxPriceAllowed));
                              maxVal = Math.max(minPriceAllowed, Math.min(maxVal, maxPriceAllowed));

                              // Ensure min ≤ max
                              if (minVal > maxVal) minVal = maxVal;
                              if (maxVal < minVal) maxVal = minVal;

                              // Update slider values (example: dual handle)
                              priceSlider.value1 = minVal;
                              priceSlider.value2 = maxVal;

                              // Update textboxes with $
                              minPriceBox.value = formatPrice(minVal);
                              maxPriceBox.value = formatPrice(maxVal);
                          }

                          // Event listeners for textbox
                          [minPriceBox, maxPriceBox].forEach(box => {
                              // Only allow numbers while typing
                              box.addEventListener('input', function() {
                                  this.value = this.value.replace(/[^0-9]/g, '');
                              });
                              box.addEventListener('change', handlePriceInput);
                              box.addEventListener('blur', handlePriceInput);
                          });

                      });
                                            </script>  
