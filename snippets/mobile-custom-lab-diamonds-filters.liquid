                                        const minRatioBox = document.getElementById('minratioValue');
                                        const maxRatioBox = document.getElementById('maxratioValue');

                                        // Minimum and maximum ratio allowed
                                        const minRatioValue = parseFloat(sliderRatio.min);
                                        const maxRatioValue = parseFloat(sliderRatio.max);

                                        // Format number
                                        function formatRatio(num) {
                                            return parseFloat(num);
                                        }

                                        // Update textbox values from slider
                                        function updateRatioValues() {
                                            minRatioBox.value = formatRatio(sliderRatio.value1 || minRatioValue);
                                            maxRatioBox.value = formatRatio(sliderRatio.value2 || maxRatioValue);
                                        }

                                        // Initial load
                                        updateRatioValues();

                                        // Slider → textbox
                                        sliderRatio.addEventListener('change', updateRatioValues);

                                        // Validate textbox input
                                        function handleRatioInput() {

                                            let minVal = parseFloat(minRatioBox.value.replace(/[^0-9.]/g, ''));
                                            let maxVal = parseFloat(maxRatioBox.value.replace(/[^0-9.]/g, ''));

                                            // If invalid
                                            if (isNaN(minVal)) minVal = minRatioValue;
                                            if (isNaN(maxVal)) maxVal = maxRatioValue;

                                            // Clamp values
                                            minVal = Math.max(minRatioValue, Math.min(minVal, maxRatioValue));
                                            maxVal = Math.max(minRatioValue, Math.min(maxVal, maxRatioValue));

                                            // Ensure min ≤ max
                                            if (minVal > maxVal) minVal = maxVal;
                                            if (maxVal < minVal) maxVal = minVal;

                                            // Update slider
                                            sliderRatio.value1 = minVal;
                                            sliderRatio.value2 = maxVal;

                                            // Update textboxes
                                            minRatioBox.value = formatRatio(minVal);
                                            maxRatioBox.value = formatRatio(maxVal);
                                        }

                                        // Events for textboxes
                                        [minRatioBox, maxRatioBox].forEach(box => {

                                            // Allow numbers only
                                            box.addEventListener('input', function() {
                                                this.value = this.value.replace(/[^0-9.]/g, '');
                                            });

                                            box.addEventListener('change', handleRatioInput);
                                            box.addEventListener('blur', handleRatioInput);

                                        });

                                    });
