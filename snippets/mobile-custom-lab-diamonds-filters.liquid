                                    data-li="certified"
                                    aria-label="Toggle certified filter options"
                                    aria-controls="filter-certified"
                                    type="button"
                                  >
                                  {% render 'icon-down-arrow' %}
                                  </button>
                              </div>
                               <div class="filter__list-content">
                              <div class="filter-info">
                                <div class="tooltip mobile-tooltip">
                                  <button type="button" data-mb-tooltip="certified"  aria-controls="tooltip-certified" class="dmd-toltiptext"  data-mb-tooltip="certified">Certified Guide</button>
                                  <div class="tooltiptext" id="tooltip-certified"  role="dialog"  aria-labelledby="tooltip-certified-title">
                                    <div class="tooltip-title" id="tooltip-certified-title">
                                      Certified  
                                      <button class="icon-close vdb-lb-close-tooltip filter-mobile-view-close" aria-lable="close Fluor. Guide tooltip">
                                        {% render 'icon-close' %}
                                      </button>
                                    </div>
                                    {% if block.settings.description_textarea_certified_by != blank %}
                                      <p class="tooltip-content">{{ block.settings.description_textarea_certified_by | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}</p>
                                    {% endif %}
                                  </div>
                                </div>
                              </div>
                              <div class="select-wrapper">
                                 
                                  <select class="sustainability-select hide" id="certified-by-select-mobile" multiple>
                                       {% assign defaultCertifiedBy = certified_by_value_array.first %}
                                        {% if labParams == blank %}
                                    {% assign labParams = defaultCertifiedBy %}
                                   {% endif %}  
                                    {% assign labIndex = 0 %}

                                    {% for item in certified_by_value_array %}
                                        {% assign current_item = item | strip %}

                                      {% if labParams contains current_item %}
                                         <option value="{{ item }}" selected>{{ item }}</option>
                                      {% else %}  
                                        <option value="{{ item }}">{{ item }}</option>
                                        {% endif %}
                                     
                                    {% endfor %}
                                  </select>
                                  {% render 'icon', name: 'down-caret', icon_class: 'select-caret hide' %}
                              </div>
                              <div
                                class="dmdfilter-swatches certified-swatches"
                                role="radiogroup"
                                aria-label="Select Certified"
                                data-option-name="Certified"
                                 data-multiple="true"
                              >
                                  {% assign defaultCertifiedBy = certified_by_value_array| join: ',' | remove: ' ' %}
                                    
                                    {% for item in certified_by_value_array %}
                                      {% assign active_class = '' %}
                                      {% assign all_hide_class = '' %}
                                      {% assign current_item = item | strip %}
                                        {% if current_item == 'All' %}
                                       {% assign all_hide_class = 'hide' %}
                                       {% endif %}
                                       {% if labParams contains current_item %}
                                        {% assign active_class = 'active' %}
                                        {% endif %}

                                <button
                                  type="button"
                                  class="swatches-tab {{active_class }} {{all_hide_class }}"
                                  role="radio"
                                  aria-checked="true"
                                  tabindex="0"
                                  data-value="{{ item }}"
                                >
                                 {{ item }}
                                </button>
                                 {% endfor %}
                              </div>
                               </div>
                            </li> 
                    {% endcase %}
                  {% endfor %}
                </ul>
                </div> 
              </li>           
                
      </ul>
      <div class="filters-toggle-container">
        <div class="filter-buttons">
           <button class="button button--secondary reset-button vdb-lb-clear-all-filters1">RESET FILTERS</button>
          <button class="button button--primary results-button vdb-lb-apply-all-filters vdb-lb-advanced-filter-mobile-view-close">Apply Filters</button>
        </div>
        <a  href="jascript:;" class="viewdetail vdb-lb-clear-all-filters vdb-lb-advanced-filter-mobile-view-close" aria-label="Clear All Filters">Clear All Filters</a>
      </div>
    </section>
    <footer></footer>
  </div>
</div>
<div class="filter__sidebar-overlay" style="top: 0px;"></div>
<div id="diamond-filter" class="filter__sidebar-container dmd-detail-filter" role="dialog" aria-modal="true"
  aria-labelledby="filter-title" tabindex="-1">
</div>
<div class="filter__sidebar-overlay dmd-detail-filter-close" style="top: 0px;"></div> 



<script>
  document.addEventListener("DOMContentLoaded", function () {
    var overlay = document.querySelector(".filter__sidebar-overlay");
    var htmlTag = document.documentElement; // <html>

    if (overlay) {
      overlay.addEventListener("click", function () {
        // sidebar classes remove
        document.querySelectorAll(".sidebar-active").forEach(function (el) {
          el.classList.remove("sidebar-active");
        });
        let filterListOpenElements = document.getElementsByClassName('filter__list-open');
                filterListOpenElements = Array.prototype.slice.call(filterListOpenElements);
                filterListOpenElements.forEach(e => e.classList.remove('filter__list-open'));

                let mobileTooltipActiveElements = document.getElementsByClassName('mobile-tooltip-active');
                mobileTooltipActiveElements = Array.prototype.slice.call(mobileTooltipActiveElements);
                mobileTooltipActiveElements.map(e => e.classList.remove('mobile-tooltip-active'));

        // html class remove
        htmlTag.classList.remove("open-dmdfilter");
      });
    } 
});
</script>






