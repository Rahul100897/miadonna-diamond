                                  <input 
                                    type="text" 
                                    id="mindepthValue" 
                                    class="range-box"
                                    aria-label="Minimum depth"
                                    placeholder="0%"
                                  >

                                  <input 
                                    type="text" 
                                    id="maxdepthValue" 
                                    class="range-box"
                                    aria-label="Maximum depth"
                                    placeholder="100%"
                                  >
                                </div>

                                <script>
                                document.addEventListener('DOMContentLoaded', function() {

                                    const depthSlider = document.getElementById('slider_depth_mia_mobile');
                                    const minDepthBox = document.getElementById('mindepthValue');
                                    const maxDepthBox = document.getElementById('maxdepthValue');

                                    // Define min/max allowed values
                                    const minDepthValue = parseFloat(depthSlider.min);
                                    const maxDepthValue = parseFloat(depthSlider.max);

                                    // Format number + "%"
                                    function formatDepth(num) {
                                        return parseFloat(num) + '%';
                                    }

                                    // Update textboxes from slider values
                                    function updateDepthValues() {
                                        minDepthBox.value = formatDepth(depthSlider.value1);
                                        maxDepthBox.value = formatDepth(depthSlider.value2);
                                    }

                                    // Initial load
                                    updateDepthValues();

                                    // Slider → textbox
                                    depthSlider.addEventListener('change', updateDepthValues);

                                    // Validate input
                                    function handleDepthInput() {

                                        let minVal = parseFloat(minDepthBox.value.replace(/[^0-9.]/g, ''));
                                        let maxVal = parseFloat(maxDepthBox.value.replace(/[^0-9.]/g, ''));

                                        if (isNaN(minVal)) minVal = minDepthValue;
                                        if (isNaN(maxVal)) maxVal = maxDepthValue;

                                        // Clamp values
                                        minVal = Math.max(minDepthValue, Math.min(minVal, maxDepthValue));
                                        maxVal = Math.max(minDepthValue, Math.min(maxVal, maxDepthValue));

                                        // Ensure min ≤ max
                                        if (minVal > maxVal) minVal = maxVal;
                                        if (maxVal < minVal) maxVal = minVal;

                                        // Update slider values
                                        depthSlider.value1 = minVal;
                                        depthSlider.value2 = maxVal;

                                        // Update textboxes
                                        minDepthBox.value = formatDepth(minVal);
                                        maxDepthBox.value = formatDepth(maxVal);
                                    }

                                    // Event listeners
                                    [minDepthBox, maxDepthBox].forEach(box => {

                                        box.addEventListener('input', function() {
                                            this.value = this.value.replace(/[^0-9.]/g, '');
                                        });

                                        box.addEventListener('change', handleDepthInput);
                                        box.addEventListener('blur', handleDepthInput);

                                    });

                                });
                                </script>
