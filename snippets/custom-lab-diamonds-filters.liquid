                      {% render 'icon-shape-rose-brilliant-cut' %}
                    {% elsif selected_shape_handle == 'rose' %}
                      {% render 'icon-shape-rose-cut' %}
                    {% endif %}
                </span>
              {% endif %}   
            {% endif %}    
          {% endif %}
      {% endfor %}   
      {% if Otherselectedcount > 0 %}
  <span class="shap-svg"> + {{ Otherselectedcount }} </span>
{% endif %}
       {%  if selected_shapeIndex.size >=5  %}
        {% assign countshap = 0 %}
      {% else %}  
        {%  if selected_shapeIndex !=blank  %}
        {% assign countshap = countshap | minus: selected_shapeIndex.size %}
        {% endif %}
    {% endif %} 
      {% for i in shapeArray %}
          {% assign shape_label_id = 'main_title_shape_' | append: i %}
          {% assign shape_display_id = 'main_title_shape_checkbox_' | append: i %}
          {% assign shape_icon_id = 'main_title_shape_icon_' | append: i %}
