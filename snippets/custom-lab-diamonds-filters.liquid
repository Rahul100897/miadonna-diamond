                    {% elsif selected_shape_handle == 'half-moon' %}
                      {% render 'icon-shape-half-moon-cut' %}
                    {% elsif selected_shape_handle == 'baguette' %}
                      {% render 'icon-shape-baguette-cut' %}
                    {% elsif selected_shape_handle == 'rose-brilliant' %}
                      {% render 'icon-shape-rose-brilliant-cut' %}
                    {% elsif selected_shape_handle == 'rose' %}
                      {% render 'icon-shape-rose-cut' %}
                    {% endif %}
                </span>
               {% else %} 
                
                 <span class="shap-svg {% if selected_shapeIndex contains j %}active{% endif %}">
                    {% if selected_shape_handle == 'round' %}
                      {% render 'icon-shape-round-cut' %}
                    {% elsif selected_shape_handle == 'princess' %}
                      {% render 'icon-shape-princess-cut' %}
                    {% elsif selected_shape_handle == 'cushion' %}
                      {% render 'icon-shape-cushion-cut' %}
                    {% elsif selected_shape_handle == 'oval' %}
                      {% render 'icon-shape-oval-cut' %}
