        <span class="filter-label">Color:</span>
        <span class="filter-value"> {{colorParamsArraylabel }}
{% if colorParamsArrayFirst != colorParamsArrayLast %}
 {{ colorcount }} {% endif %}</span>
        <span class="dmd-rightarrow" aria-hidden="true">
          {% render 'icon-arrowright' %}
