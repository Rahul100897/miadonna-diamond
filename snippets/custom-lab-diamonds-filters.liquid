                                              {% endif %}
                                      {% endif %}
                                              <div>{{ block.settings[fancy_label_id] }}</div>
                                          </button>
                                      </div>
                                  {% endif %}
                              {% endfor %}
                            </div>
                            <div class="swiper-scrollbar swiper-scrollbar-fancy"></div>
                          </div>
                        </div>
