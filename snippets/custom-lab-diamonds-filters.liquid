{% endfor %}
   <button
    class="filter-pill filter-pill--all vdb-lb-advanced-filter-mobile-view-open"
    data-id=""
    type="button"
    role="listitem"
    aria-label="Open all filters"
  >
    ALL FILTERS
    <span class="dmd-rightarrow" aria-hidden="true">
      {% render 'icon-arrowright' %}
    </span>
  </button>

</div>



<div class="custom-filters-group one-whole">
    <div class="loading-block text-align-center" style="background-color: transparent;display: none;">
      <div class="inner">
        <svg width="90" height="90" viewBox="0 0 150 150">
          <g fill="none" stroke="#fca999" stroke-width="3" stroke-miterlimit="10">
            <path class="logo-1" d="M75.1880276 38.9158992l34.679749 35.443358-35.4419284 34.6783502-34.679749-35.443358z" stroke-width="3.00015"></path>
            <path class="logo-2" d="M75.79 145.261l-50.697-20.185-21.575-50.12 20.184-50.697L73.823 2.684l50.699 20.184 21.573 50.12-20.186 50.697zM73.823 2.684l1.365 36.229m-.764 70.117l1.366 36.231m34.075-70.907l36.23-1.366M3.518 74.956l36.23-1.366m70.117.764l16.044 49.331M74.424 109.03l51.485 14.655M39.748 73.59l-14.655 51.486m49.331-16.046l-49.331 16.046M23.702 24.259L39.748 73.59M23.702 24.259l51.486 14.654m0 0l49.334-16.045m0 0l-14.657 51.486"></path>
          </g>
        </svg>
        <header class="text-style-footnote" style="color: #3c3737;">Loading filters</header>
      </div>
    </div>
    <div class="filter-sets">
       
          <div class="filter-sets-group filter-sets-group-custom">
            {% for block in section.blocks %}
                {% case block.type %}
                    {% when 'Shape' %}
                        <div class="filter-desktop-whole filter-set filter-set--shapes one-whole large-down--one-whole{% if block.settings['include_in_advanced_filter_checkbox_shape'] == true %}{{- is_advanced_class -}}{% endif %}">
                            <div class="filter-set-title-wrapper">
                                <div class="filter-set-title">
                                    <span>Shape</span>
                                    <div class="filter-info">
                                        <div class="tooltip">
                                            <img src="https://scdn.speedsize.com/d9acbe11-c0cc-4d19-a1ce-748a0fd38b05/cdn.shopify.com/s/files/1/1164/4258/files/info.png?v=1685953801" width="22px" height="22px" class="icon-info" alt="" >
                                            <span class="tooltiptext">
                                                <p class="tooltip-title">Shape</p>
                                                {% if block.settings.description_textarea_shape != blank %}<p class="tooltip-content">{{ block.settings.description_textarea_shape | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}</p>{% endif %}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="filter-set-content">
                                <div class="options vdb-lb-slider-shape" style="max-width: 100% !important;">
                                      {% assign shapeString = '' %}
                                      {% for i in (1..14) %}
                                          {% assign shape_label_id = 'main_title_shape_' | append: i %}
                                          {% assign shape_display_id = 'main_title_shape_checkbox_' | append: i %}
                                        {% if block.settings[shape_label_id] != blank and block.settings[shape_display_id] == true %}
                                          {% assign shapeString = shapeString | append: ',' | append: i %}
                                          {% assign shapeData = shapeData | append: ',' | append: block.settings[shape_label_id] %}
                                        {% endif %}
                                      {% endfor %}
                                          
                                      {% assign shapeData = shapeData | remove_first: ',' %}
                                      {{shapeData }}
                                      {% assign shapeArray = shapeString | remove_first: ',' | split: ',' %}
                                        {% assign shapeIndex = 0 %}
                                        {% assign shapeParams = '' %}
                                        {% if labGrownPageQueryArray != blank %}
                                        {% for param in labGrownPageQueryArray %}
                                          {%- if param contains "shape" -%}
                                            {% assign shapeKey = param | split: '=' | first | strip %}
                                            {% if shapeKey != "supported_shapes" %}
                                              {% assign shapeParams = param | split: '=' | last | strip %}
                                              {% assign shapeParams = shapeParams | replace: "Cut", "" | strip %}
                                            {% endif %}
                                          {%- endif -%}
                                        {% endfor %}
                                      {% else %}
                                      {% endif %}

                                      {% assign defaultShapeIndex = -1 %}
                                      {% for i in shapeArray %}
                                        {% assign shape_label_id = 'main_title_shape_' | append: i %}
                                        {% assign shape_display_id = 'main_title_shape_checkbox_' | append: i %}
                                        {% assign shape_icon_id = 'main_title_shape_icon_' | append: i %}
                                        {% if block.settings[shape_label_id] != blank and block.settings[shape_display_id] == true %}
                                          
                                          {% assign shape_handle = block.settings[shape_label_id] | handle | downcase  %}
                                          {% assign class_name_shape = 'vdb-list-item-shape-style-' | append: shape_handle  %}

                                            {% if shapeParams == block.settings[shape_label_id] %} {% assign shapeIndex = i %} {% endif %}
                                              {% unless i != defaultShapeIndex %} {% assign defaultShape = block.settings[shape_label_id] %}{% endunless %}
                                              <div class="option {{ class_name_shape }} {% unless i != shapeIndex %}active-state{% endunless %}">
                                                  <button class="vdb-list-item-a-shape-style" data-module="{{ class_name_shape }}" data-shape-value="{{ block.settings[shape_label_id] }}">
                                                      {% if block.settings[shape_icon_id] != blank %}
                                                        {{ block.settings[shape_icon_id] | image_url: width: 300 | image_tag | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}
                                                      {% else %}
                                                        {% if shape_handle == 'round' %}
                                                          {% render 'icon-shape-round-cut' %}
                                                        {% elsif shape_handle == 'princess' %}
                                                          {% render 'icon-shape-princess-cut' %}
                                                        {% elsif shape_handle == 'cushion' %}
                                                          {% render 'icon-shape-cushion-cut' %}
                                                        {% elsif shape_handle == 'oval' %}
                                                          {% render 'icon-shape-oval-cut' %}
                                                        {% elsif shape_handle == 'emerald' %}
                                                          {% render 'icon-shape-emerald-cut' %}
                                                        {% elsif shape_handle == 'asscher' %}
                                                          {% render 'icon-shape-asscher-cut' %}
                                                        {% elsif shape_handle == 'radiant' %}
                                                          {% render 'icon-shape-radiant-cut' %}
                                                        {% elsif shape_handle == 'pear' %}
                                                          {% render 'icon-shape-pear-cut' %}
                                                        {% elsif shape_handle == 'heart' %}
                                                          {% render 'icon-shape-heart-cut' %}
                                                        {% elsif shape_handle == 'marquise' %}
                                                          {% render 'icon-shape-marquise-cut' %}
                                                        {% elsif shape_handle == 'oval-rose' %}
                                                          {% render 'icon-shape-oval-rose-cut' %}
                                                        {% elsif shape_handle == 'trillion' or shape_handle == 'trilliant' %}
                                                          {% render 'icon-shape-trillion-cut' %}
                                                        {% elsif shape_handle == 'half-moon' %}
                                                          {% render 'icon-shape-half-moon-cut' %}
                                                        {% elsif shape_handle == 'baguette' %}
                                                          {% render 'icon-shape-baguette-cut' %}
                                                        {% elsif shape_handle == 'rose-brilliant' %}
                                                          {% render 'icon-shape-rose-brilliant-cut' %}
                                                        {% elsif shape_handle == 'rose' %}
                                                          {% render 'icon-shape-rose-cut' %}
                                                        {% endif %}
                                                      {% endif %}
                                                      <div>{{ block.settings[shape_label_id] }}</div>
                                                  </button>
                                              </div>
                                          {% endif %}
                                      {% endfor %}
                                </div>
                            </div>
                        </div>
                    {% when 'Color' %}
                        <div class="filter-desktop-whole filter-set filter-set--color one-half large-down--one-whole{% if block.settings['include_in_advanced_filter_checkbox_color'] == true %}{{- is_advanced_class -}}{% endif %}">
                            <div class="filter-set-title-wrapper">
                                <div class="filter-set-title">
                                    <span>Color</span>
                                    <div class="filter-info">
                                        <div class="tooltip">
                                            <img src="https://scdn.speedsize.com/d9acbe11-c0cc-4d19-a1ce-748a0fd38b05/cdn.shopify.com/s/files/1/1164/4258/files/info.png?v=1685953801" width="22px" height="22px" class="icon-info" alt="" >
                                            <span class="tooltiptext">
                                              <p class="tooltip-title">Color</p>
                                              {% if block.settings.description_textarea_color != blank %}<p class="tooltip-content">{{ block.settings.description_textarea_color | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}</p>{% endif %}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="filter-set-content">
                              <div class="range-slider range-target">
                                <div class="range-base">
                                  {% assign color_values = block.settings['main_value_color_1'] %}
                                  {% assign colorParams = '' %}
                                  {% if labGrownPageQueryArray != blank %}
                                    {% for param in labGrownPageQueryArray %}
                                      {%- if param contains "color" -%}
                                        {% assign colorFirstParams = param | split: '=' | first | url_decode | strip %}
                                        {%- if colorFirstParams == "color" -%}
                                          {% assign colorParams = param | split: '=' | last | url_decode | strip %}
                                        {%- endif -%}
                                      {%- endif -%}
                                    {% endfor %}
                                  {% endif %}
                                  {% assign color_value_array = color_values | split: ',' %}

                                  {% assign colorParamsArray = '' %}
                                  {% if colorParams != blank %}
                                    {% assign colorParamsArray = colorParams | split: ',' %}
                                  {% else %}
                                    {% assign colorParamsArray = color_values | split: ',' %}  
                                    {% assign colorParamsArray = colorParamsArray %}
                                  {% endif %}
                                  {% assign colorValues = color_values |  split: ',' %}
                                  {% assign defaultColor = color_values %}
                                  {% assign colorData = color_values %}

                                  <tc-range-slider id="slider_color_mia"
                                    min="{{ color_value_array | first }}"
                                    max="{{ color_value_array | last }}"
                                    value1="{{ colorParamsArray | first }}"
                                    value2="{{ colorParamsArray | last }}"
                                    data="{{ color_values }}" 
                                    marks="true"
                                    marks-count="{{ color_value_array | size }}"
                                    marks-values-count="{{ color_value_array | size }}"
                                    marks="true"
                                    marks-count="8"
                                    marks-values-count="8"
                                    mousewheel-disabled="true"
                                    pointer-bg="#fca999"
                                    pointer-bg-hover="#fca999"
                                    pointer-bg-focus="#fca999"
                                    pointer-border="1px solid #fca999"
                                    pointer-border-hover="1px solid #fca999"
                                    pointer-border-focus="1px solid #fca999"
                                    slider-bg="#ebebeb"
                                    slider-bg-fill="#fca999"
                                    slider-width="100%"
                                    slider-height="5px"
                                    generate-labels="false"
                                    css-links="{{ 'tc-range-box-shadow.css' | asset_url }};"
                                  />
                                </div>
                              </div>
                            </div>
                        </div>
                    {% when 'Carat' %}


                      {% assign caratMinParams = '2' %}
                      {% assign caratMaxParams = '' %}
                      {% assign ringHandle = 'No' %}
                      {% if labGrownPageQueryArray != blank %}
                        {% for param in labGrownPageQueryArray %}
                          {%- if param contains "ring-handle" -%}
                            {% assign ringHandle = 'Yes' %}
                          {%- endif -%}
                        {% endfor %}

                        {% for param in labGrownPageQueryArray %}
                          {%- if param contains "min_carat" -%}
                            {% assign caratMinParams = param | split: '=' | last | strip | to_i %}
                          
                          {%- endif -%}
                        {% endfor %}
                      
                        {% for param in labGrownPageQueryArray %}
                          {%- if param contains "max_carat" -%}
                          
                            {% assign caratMaxParams = param | split: '=' | last | strip | to_i %}
                          
                          {%- endif -%}
                        {% endfor %}
                      {% else %}
                        
                      {% endif %}
                      {%- assign defaultCaratMin = caratMinParams -%}
                      {%- assign defaultCaratMax = caratMaxParams -%}
                      
                      {% if carat_metafields != blank %}
                        {% assign caratMetafields = carat_metafields |  split: '-' %}
                        {% assign minCaratValue = caratMetafields | first %}
                        {% assign maxCaratValue = caratMetafields | last %}
                      {% else %}
                        {% assign minCaratValue = block.settings.main_title_carat_min %}
                        {% assign maxCaratValue = block.settings.main_title_carat_max %}
                      {% endif %}
                      {%- assign defaultCaratMin = minCaratValue -%}
                      {%- assign defaultCaratMax = maxCaratValue -%}

                      {% if ringHandle == 'Yes' %}
                        {% assign minCaratValue = caratMinParams %}
                        {% assign caratMinParams = '0' %}
                        {% assign maxCaratValue = caratMaxParams %}
                      {% endif %}
                      {% if caratMaxParams == blank %}
                        {% assign caratMaxParams = maxCaratValue %}
                      {% endif %}
                    {% if caratMinParams == blank %}
                        {% assign caratMinParams = minCaratValue %}
                      {% endif %}
                        


                      <div class="filter-desktop-whole filter-set filter-set--carat one-half large-down--one-whole{% if block.settings['include_in_advanced_filter_checkbox_carat'] == true %}{{- is_advanced_class -}}{% endif %}">
                          <div class="filter-set-title-wrapper">
                              <div class="filter-set-title">
                                  <span>Carat</span>
                                  <div class="filter-info">
                                      <div class="tooltip">
                                          <img src="https://scdn.speedsize.com/d9acbe11-c0cc-4d19-a1ce-748a0fd38b05/cdn.shopify.com/s/files/1/1164/4258/files/info.png?v=1685953801" width="22px" height="22px" class="icon-info" alt="" >
                                          <span class="tooltiptext">
                                            <p class="tooltip-title">Carat Size</p>
                                            {% if block.settings.description_textarea_carat != blank %}<p class="tooltip-content">{{ block.settings.description_textarea_carat | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}</p>{% endif %}
                                          </span>
                                      </div>
                                  </div>
                              </div>
                          </div>
                          <div class="filter-set-content">
                              <div class="range-slider range-target">
                                  <div class="range-base">
                                      <tc-range-slider id="slider_carat_mia"
                                        min="{{ minCaratValue }}"
                                        max="{{ maxCaratValue }}"
                                        value1="{{ caratMinParams }}"
                                        value2="{{ caratMaxParams }}"
                                        moving-tooltip="true"
                                        moving-tooltip-distance-to-pointer="-30"
                                        moving-tooltip-bg="transparent"
                                        moving-tooltip-text-color="#3c3737"
                                        moving-tooltip-width="70"
                                        moving-tooltip-height="20"
                                        mousewheel-disabled="true"
                                        pointer-bg="#fca999"
                                        pointer-bg-hover="#fca999"
                                        pointer-bg-focus="#fca999"
                                        pointer-border="1px solid #fca999"
                                        pointer-border-hover="1px solid #fca999"
                                        pointer-border-focus="1px solid #fca999"
                                        slider-bg="#ebebeb"
                                        slider-bg-fill="#fca999"
                                        moving-tooltip-units=" CT"
                                        slider-width="100%"
                                        slider-height="5px"
                                        generate-labels="false"
                                        css-links="{{ 'tc-range-box-shadow.css' | asset_url }};"
                                      />
                                  </div>
                              </div>
                          </div>
                      </div>
                    {% when 'Price' %}
                      {% assign priceMinParams = '' %}
                      {% assign priceMaxParams = '' %}
                      {% if labGrownPageQueryArray != blank %}
                        {% for param in labGrownPageQueryArray %}
                          {%- if param contains "min_price" -%}
                            {% assign priceMinParams = param | split: '=' | last | strip | to_i %}
                          
                          {%- endif -%}
                        {% endfor %}

                        {% for param in labGrownPageQueryArray %}
                          {%- if param contains "max_price" -%}
                            {% assign priceMaxParams = param | split: '=' | last | strip | to_i %}
                          
                          {%- endif -%}
                        {% endfor %}
                      {% else %}
                        
                      {% endif %}
                      {%- assign defaultPriceMin = priceMinParams -%}
                      {%- assign defaultPriceMax = priceMaxParams -%}
                      <div class="filter-desktop-whole filter-set filter-set--price one-half large-down--one-whole{% if block.settings['include_in_advanced_filter_checkbox_price'] == true %}{{- is_advanced_class -}}{% endif %}">
                        <div class="filter-set-title-wrapper">
                          <div class="filter-set-title">
                            <span>Price</span>
                            <div class="filter-info">
                              <div class="tooltip">
                                <img src="https://scdn.speedsize.com/d9acbe11-c0cc-4d19-a1ce-748a0fd38b05/cdn.shopify.com/s/files/1/1164/4258/files/info.png?v=1685953801" width="22px" height="22px" class="icon-info" alt="" >
                                <span class="tooltiptext">
                                  <p class="tooltip-title">Price</p>
                                  {% if block.settings.description_textarea_price != blank %}<p class="tooltip-content">{{ block.settings.description_textarea_price | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}</p>{% endif %}
                                </span>
                              </div>
                            </div>
                          </div>
                        </div>
                        
                        {% if price_metafields != blank %}
                          {% assign priceMetafields = price_metafields |  split: '-' %}
                          {% assign minPriceValue = priceMetafields | first %}
                          {% assign maxPriceValue = priceMetafields | last %}
                        {% else %}
                          {% assign minPriceValue = block.settings.main_title_carat_min %}
                          {% assign maxPriceValue = block.settings.main_title_carat_max %}
                        {% endif %}
                        
                        {%- assign defaultPriceMin = minPriceValue -%}
                        {%- assign defaultPriceMax = maxPriceValue -%}
                        {% if priceMinParams == blank %}{% assign priceMinParams = minPriceValue %}{% endif %}
                        {% if priceMaxParams == blank %}{% assign priceMaxParams = maxPriceValue %}{% endif %}

                        <div class="filter-set-content">
                          <div class="range-slider range-target">
                            <div class="range-base">
                              <tc-range-slider id="slider_price_mia"
                                min="{{ minPriceValue }}"
                                max="{{ maxPriceValue }}"
                                value1="{{ priceMinParams }}"
                                value2="{{ priceMaxParams }}"
                                step="0.01"
                                moving-tooltip="true"
                                moving-tooltip-distance-to-pointer="-30"
                                moving-tooltip-bg="transparent"
                                moving-tooltip-text-color="#3c3737"
                                moving-tooltip-width="70"
                                moving-tooltip-height="20"
                                mousewheel-disabled="true"
                                pointer-bg="#fca999"
                                pointer-bg-hover="#fca999"
                                pointer-bg-focus="#fca999"
                                pointer-border="1px solid #fca999"
                                pointer-border-hover="1px solid #fca999"
                                pointer-border-focus="1px solid #fca999"
                                slider-bg="#ebebeb"
                                slider-bg-fill="#fca999"
                                moving-tooltip-units="$"
                                moving-tooltip-units-type="prefix"
                                slider-width="100%"
                                slider-height="5px"
                                generate-labels="false"
                                css-links="{{ 'tc-range-box-shadow.css' | asset_url }};"
                              />
                            </div>
                          </div>
                        </div>
                      </div>
                    {% when 'Clarity' %}
                      <div class="filter-desktop-whole filter-set filter-set--clarity one-half large-down--one-whole{% if block.settings['include_in_advanced_filter_checkbox_clarity'] == true %}{{- is_advanced_class -}}{% endif %}">
                        <div class="filter-set-title-wrapper">
                          <div class="filter-set-title">
                            <span>Clarity</span>
                            <div class="filter-info">
                              <div class="tooltip">
                                <img src="https://scdn.speedsize.com/d9acbe11-c0cc-4d19-a1ce-748a0fd38b05/cdn.shopify.com/s/files/1/1164/4258/files/info.png?v=1685953801" width="22px" height="22px" class="icon-info" alt="" >
                                <span class="tooltiptext">
                                  <p class="tooltip-title">Clarity</p>
                                  {% if block.settings.description_textarea_clarity != blank %}<p class="tooltip-content">{{ block.settings.description_textarea_clarity | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}</p>{% endif %}
                                </span>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div class="filter-set-content">
                          <div class="range-slider range-target">
                            <div class="range-base">
                              {% assign clarity_values = '' %}
                              {% for i in (1..9) %}
                                {% assign clarity_label_id = 'main_title_clarity_' | append: i %}
                                {% assign clarity_display_id = 'main_title_clarity_checkbox_' | append: i %}
                                {% if block.settings[clarity_label_id] != blank and block.settings[clarity_display_id] == true %}
                                  {% assign clarity_values = clarity_values | append: block.settings[clarity_label_id] | append: ',' %}
                                {% endif %}
                              {% endfor %}
                              {% assign clarity_value_array = clarity_values | replace_last: ',', '' | split: ',' %}
                            {% assign clarity_value_array = clarity_value_array %} 

                              {% assign clarityParams = '' %}
                              {% if labGrownPageQueryArray != blank %}
                                {% for param in labGrownPageQueryArray %}
                                  {%- if param contains "clarity" -%}
                                    {% assign clarityParams = param | split: '=' | last | url_decode | strip %}
                                  {%- endif -%}
                                {% endfor %}
                              {% endif %}
                            
                              {% assign clarityParamsArray = '' %}
                              {% if clarityParams != blank %}
                                {% assign clarityParamsArray = clarityParams | split: ',' %}
                              {% else %}
                                {% assign clarityParamsArray = clarity_values | replace_last: ',', '' | split: ',' %}  
                                {% assign clarityParamsArray = clarityParamsArray %} 
                              {% endif %}
                              {% assign clarityValues = clarity_values | replace_last: ', ', '' |  split: ',' %}
                              {% assign defaultClarity = clarityValues | join: ',' %} 
                              {% assign clarityData = clarityValues | join: ',' %} 

                              
                              <tc-range-slider id="slider_clarity_mia"
                                min="{{ clarity_value_array | first }}"
                                max="{{ clarity_value_array | last }}"
                                value1="{{ clarityParamsArray | first }}"
                                value2="{{ clarityParamsArray | last }}"
                                data="{{ clarityValues | join: ',' }}" 
                                marks="true"
                                marks-count="{{ clarity_value_array | size }}"
                                marks-values-count="{{ clarity_value_array | size }}"
                                mousewheel-disabled="true"
                                pointer-bg="#fca999"
                                pointer-bg-hover="#fca999"
                                pointer-bg-focus="#fca999"
                                pointer-border="1px solid #fca999"
                                pointer-border-hover="1px solid #fca999"
                                pointer-border-focus="1px solid #fca999"
                                slider-bg="#ebebeb"
                                slider-bg-fill="#fca999"
                                slider-width="100%"
                                slider-height="5px"
                                generate-labels="false"
                                css-links="{{ 'tc-range-box-shadow.css' | asset_url }};"
                              />
                            </div>
                          </div>
                        </div>
                      </div>
