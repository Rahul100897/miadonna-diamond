     {% endif %}
   {% endfor %}
    
    </span>
      <span class="dmd-rightarrow" aria-hidden="true">
      {% render 'icon-arrowright' %}
    </span>
  </button>
   {% when 'Carat' %}
    
    {% assign caratMinParams = '2' %}
    {% assign caratMaxParams = '' %}
    {% assign ringHandle = 'No' %}
    {% if labGrownPageQueryArray != blank %}
    {% for param in labGrownPageQueryArray %}
      {%- if param contains "ring-handle" -%}
        {% assign ringHandle = 'Yes' %}
      {%- endif -%}
    {% endfor %}

    {% for param in labGrownPageQueryArray %}
      {%- if param contains "min_carat" -%}
        {% assign caratMinParams = param | split: '=' | last | strip | to_i %}
      {%- endif -%}
    {% endfor %}
    {% for param in labGrownPageQueryArray %}
      {%- if param contains "max_carat" -%}
        {% assign caratMaxParams = param | split: '=' | last | strip | to_i %}
      {%- endif -%}
    {% endfor %}
    {% else %}
    {% endif %}
    {%- assign defaultCaratMin = caratMinParams -%}
    {%- assign defaultCaratMax = caratMaxParams -%}

    {% if carat_metafields != blank %}
    {% assign caratMetafields = carat_metafields |  split: '-' %}
    {% assign minCaratValue = caratMetafields | first %}
    {% assign maxCaratValue = caratMetafields | last %}
    {% else %}
    {% assign minCaratValue = block.settings.main_title_carat_min %}
    {% assign maxCaratValue = block.settings.main_title_carat_max %}
    {% endif %}
    {%- assign defaultCaratMin = minCaratValue -%}
    {%- assign defaultCaratMax = maxCaratValue -%}

    {% if ringHandle == 'Yes' %}
    {% assign minCaratValue = caratMinParams %}
    {% assign caratMinParams = '1' %}
    {% assign maxCaratValue = caratMaxParams %}
    {% endif %}
    {% if caratMaxParams == blank %}{% assign caratMaxParams = maxCaratValue %}{% endif %}

    {% if caratMinParams !=blank and caratMaxParams!=blank %}
     <button
    class="filter-pill vdb-lb-advanced-filter-mobile-view-open"
    type="button"
    data-filter="carat"
    role="listitem"
    aria-label="Filter by carat. Range 0.70 to 26.2 carats"
  >
    <span class="filter-label">Carat:</span>
    <span class="filter-value">{{caratMinParams }} ct - {{caratMaxParams }} ct</span>
    <span class="dmd-rightarrow" aria-hidden="true">
      {% render 'icon-arrowright' %}
    </span>
  </button>
  {% endif %}

  {% when 'Price' %}
    {% assign priceMinParams = '' %}
    {% assign priceMaxParams = '' %}
    {% if labGrownPageQueryArray != blank %}
        {% for param in labGrownPageQueryArray %}
            {%- if param contains "min_price" -%}
                {% assign priceMinParams = param | split: '=' | last | strip | to_i %}
            {%- endif -%}
        {% endfor %}

        {% for param in labGrownPageQueryArray %}
            {%- if param contains "max_price" -%}
                {% assign priceMaxParams = param | split: '=' | last | strip | to_i %}
            {%- endif -%}
        {% endfor %}
    {% else %}
    {% endif %}
    {%- assign defaultPriceMin = priceMinParams -%}
    {%- assign defaultPriceMax = priceMaxParams -%}
      
      {% if price_metafields != blank %}
        {% assign priceMetafields = price_metafields |  split: '-' %}
        {% assign minPriceValue = priceMetafields | first %}
        {% assign maxPriceValue = priceMetafields | last %}
      {% else %}
        {% assign minPriceValue = block.settings.main_title_carat_min %}
        {% assign maxPriceValue = block.settings.main_title_carat_max %}
      {% endif %}
      
      {%- assign defaultPriceMin = minPriceValue -%}
      {%- assign defaultPriceMax = maxPriceValue -%}
      {% if priceMinParams == blank %}{% assign priceMinParams = minPriceValue %}{% endif %}
      {% if priceMaxParams == blank %}{% assign priceMaxParams = maxPriceValue %}{% endif %}
    {% if priceMinParams !=blank and priceMaxParams!=blank %}
    <button
    class="filter-pill vdb-lb-advanced-filter-mobile-view-open"
    type="button"
    data-filter="price"
    role="listitem"
    aria-label="Filter by price. Range $900 to $36,252"
  >
    <span class="filter-label">Price:</span>
     {% assign min_int = priceMinParams | floor %}
{% assign min_dec = priceMinParams | append: "" | split: "." | last %}
{% assign max_int = priceMaxParams | floor %}
{% assign max_dec = priceMaxParams | append: "" | split: "." | last %}
<span class="filter-value">
{{ min_int | times: 100 | money_without_currency | split: "." | first }}{% if priceMinParams contains "." %}.{{ min_dec }}{% endif %} - 
{{ max_int | times: 100 | money_without_currency | split: "." | first }}{% if priceMaxParams contains "." %}.{{ max_dec }}{% endif %}
</span> 
    <span class="dmd-rightarrow" aria-hidden="true">
      {% render 'icon-arrowright' %}
    </span>
    </button>
   {% endif %}
{% when 'Cut' %}
    {% assign cut_values = '' %}
    {% for i in (1..6) %}
      {% assign cut_label_id = 'main_title_cut_' | append: i %}
      {% assign cut_display_id = 'main_title_cut_checkbox_' | append: i %}
      {% if block.settings[cut_label_id] != blank and block.settings[cut_display_id] == true %}
        {% assign cut_values = cut_values | append: block.settings[cut_label_id] | append: ',' %}
      {% endif %}
    {% endfor %}
    {% assign cut_value_array = cut_values | replace_last: ',', '' | split: ',' %}
    {% assign defaultCut = cut_values | replace_last: ',', '' %}
    {% assign cutData = cut_values | replace_last: ',', '' %}

    {% assign cutParams = 'Excellent,Ideal' %}
    {% if labGrownPageQueryArray != blank %}
      {% for param in labGrownPageQueryArray %}
        {%- if param contains "cut" -%}
          {% assign cutParams = param | split: '=' | last | url_decode | strip %}
        {%- endif -%}
      {% endfor %}
    {% endif %}
  
    {% assign cutParamsArray = '' %}
    {% if cutParams != blank %}
      {% assign cutParamsArray = cutParams | split: ',' %}
    {% else %}
      {% assign cutParamsArray = cut_values | replace_last: ',', '' | split: ',' %}  
    {% endif %}
    {% if cutParamsArray !=blank %}
      {% assign cutParamsArrayFirst = cutParamsArray | first| replace: "+", " "  %}
      {% assign cutParamsArrayLast = cutParamsArray | last| replace: "+", " "  %}
      {% assign cutitems = cutData | split: "," %}
      {% assign cutcounting = false %}
      {% assign cutcount = 0 %}
      {% for cutitem in cutitems %}
      
        {% if cutitem == cutParamsArrayFirst %}
          {% assign cutcounting = true %}
        {% endif %}

        {% if cutcounting %}
          {% assign cutcount   = cutcount | plus: 1 %}
        {% endif %}

        {% if cutitem == cutParamsArrayLast and cutcounting %}
          {% break %}
        {% endif %}
      {% endfor %}
    <button
    class="filter-pill vdb-lb-advanced-filter-mobile-view-open"
    type="button"
    data-filter="cut"
    role="listitem"
    aria-label="Filter by cut. Selected Ideal plus one option"
  >
    <span class="filter-label">Cut:</span>
    <span class="filter-value"> {{cutParamsArrayFirst }}
{% if cutParamsArrayFirst != cutParamsArrayLast %}
 + {{ cutcount |minus : 1 }} {% endif %}</span>
    <span class="dmd-rightarrow" aria-hidden="true">
      {% render 'icon-arrowright' %}
    </span>
  </button>
  {% endif %}
  {% when 'Color' %}
    {% assign color_values = block.settings['main_value_color_1'] %}
    {% assign colorParams = 'F,D' %}
