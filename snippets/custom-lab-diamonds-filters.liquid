                                            {% assign fancyParams = param | split: '=' | last | url_decode | strip %}
                                          {%- endif -%}
                                        {% endfor %}
                                      {% else %}
                                      {% endif %}
                                      
                              {% assign defaultFancyIndex = 0 %}
                              {% for i in fancyArray %}
                                {% assign fancy_label_id = 'main_title_fancy_' | append: i %}
                                {% assign color_value_id = 'main_value_fancy_' | append: i %}
