	function removeSpecialCharacters(inputString) {
		const regex = /[^a-zA-Z0-9]/g;
		const result = inputString.replace(regex, '');
		return result;
	}

	// CENTER STONE BUTTON
    $xhr_fetch_dummy_side_stone_products_ld = '';
    $xhr_fetch_dummy_side_stone_products_gem = '';
	// Set the "Your Stone" preview image: the attached stone's real image when a
	// stone is selected (?stone-sku/?stone-handle present and its image loaded),
	// else the gray placeholder. Centralised so the async stone-load can't be
	// clobbered by a synchronous placeholder reset (which left the preview blank
	// on first load but showed it after a refresh).
	function setStonePreviewImage() {
		var img = document.getElementById("stoneImage");
		if (img == null) { return; }
		var sel = document.getElementById("select-from-inventory");
		var stoneImg = (sel && sel.dataset && sel.dataset.optionStoneImage) ? sel.dataset.optionStoneImage : '';
		var sp = new URLSearchParams(window.location.search);
		var hasStone = (sp.get('stone-sku') || sp.get('stone-handle') || '') !== '';
		if (hasStone && stoneImg && stoneImg !== 'null') {
			img.src = stoneImg;
			if (document.getElementById("stone_images") != null) {
				document.getElementById("stone_images").style.display = 'block';
			}
		} else {
			img.src = 'https://cdn.shopify.com/s/files/1/1164/4258/files/MD_Icon_Gray.svg?v=1699297537';
		}
	}

	function center_stone_logic() {
     	if (document.getElementById("stoneImage") != null) {
			// was a hard placeholder reset; re-apply the selected stone's image instead
			setStonePreviewImage();
		}
		// point no 31
		if (document.getElementById("stone_selected_value") != null) {
			document.getElementById("stone_selected_value").innerHTML =  '';
		}
		if (document.getElementsByClassName('info-border-div')[0] != null) {
			document.getElementsByClassName('info-border-div')[0].style.display = 'none';
		}
		/* if (Array.from(document.querySelectorAll('[data-compare-at-price]'))?.length > 0) {
			Array.from(document.querySelectorAll('[data-compare-at-price]')).forEach(function(el) {
				el.style.display = '';
			});
		} */
		// toggleSaleBadges(true);
		var selected_tab = "";
		if (document.querySelector("#lab-diamond") != null && document.querySelector("#lab-diamond").classList.contains("button-active")) {
			selected_tab = "ld";
		} else {
			selected_tab = "gem";
		}

		// Referance SHOP-2838
		let selectedCaratWeight = '';
		if(getParams()?.['stone-handle'] === undefined) {
			if(getParams()?.['carat_weight']) {
				document.getElementById('vdb_add_to_cart').disabled = true;
				selectedCaratWeight = parseFloat(getParams()?.['carat_weight'].replace('ct','').trim()).toFixed(2);
			}
		}

		let shapes = 'Round';
		if (priceCalculatorObj.shape) {
			shapes = priceCalculatorObj.shape.value;
		}
		let stone_weight_shapes = `{{product.metafields.attributes.stone_weight_shapes}}`; //'0.33:Round;0.50:Round;0.60:Round;0.50:Oval;0.50:Princess';
		let center_stone_variance = "{{product.metafields.attributes.center_stone_variance}}";  // '0.1';
		let min_carat_weight = "{{product.metafields.attributes.min_carat_weight}}";  // '0.5';
		min_carat_weight = min_carat_weight / 100;
		min_carat_weight = min_carat_weight.toFixed(2);
		let max_carat_weight = "{{product.metafields.attributes.max_carat_weight}}";  // '1.0';
		max_carat_weight = max_carat_weight / 100;
		max_carat_weight = max_carat_weight.toFixed(2);

		let stone_dimensions_shapes_gems = "{{product.metafields.attributes.stone_dimensions_shapes_gems}}";
		let min_carat_weight_gem = "{{product.metafields.attributes.min_carat_weight_gem}}";  // '0.5';
		let max_carat_weight_gem = "{{product.metafields.attributes.max_carat_weight_gem}}";  // '1.0';
		min_carat_weight_gem = min_carat_weight_gem / 100;
		max_carat_weight_gem = max_carat_weight_gem / 100;
		min_carat_weight_gem = min_carat_weight_gem.toFixed(2);
		max_carat_weight_gem = max_carat_weight_gem.toFixed(2);

		if (center_stone_variance != "" && min_carat_weight != "" && max_carat_weight != "") {
			min_carat_weight = parseFloat(min_carat_weight) - parseFloat(center_stone_variance);
			max_carat_weight = parseFloat(max_carat_weight) + parseFloat(center_stone_variance);
			min_carat_weight = min_carat_weight.toFixed(2);
			max_carat_weight = max_carat_weight.toFixed(2);
		}

		if (min_carat_weight_gem == 0) {
			min_carat_weight_gem = 0.18;
		}
		if (max_carat_weight_gem == 0) {
			max_carat_weight_gem = 9.50;
		}
		if (min_carat_weight == 0) {
			min_carat_weight = 0.18;
		}
		if (max_carat_weight == 0) {
			max_carat_weight = 5.87;
		}
					
		let shape_ct_for_api_arr = [];
		let shape_mm_for_api_arr = [];

        const collection_product_price = "{{ product.metafields.attributes.collection_product_price }}";
		if (selected_tab == "ld") {
			let shapes_arr = shapes.split('|'); //['Round Cut','Princess Cut','Cushion Cut']
			if (stone_weight_shapes != "") {
				shapes_arr.forEach(function (shape_val) {   //Round Cut
					let shape_wise_stone_weight_shapes_arr = [];
					let stone_weight_shapes_arr = stone_weight_shapes.split(';');   //0.33:Round;0.50:Round;0.60:Round;0.50:Oval;0.50:Princess
					stone_weight_shapes_arr.forEach(function (sw_val) {
						let shape_carat_arr = sw_val.split(':'); // ['0.33','Round']
						if (shape_carat_arr[1] != undefined && shape_val.includes(shape_carat_arr[1])) {
							if (shape_wise_stone_weight_shapes_arr[shape_carat_arr[1]] == undefined) {
								shape_wise_stone_weight_shapes_arr[shape_carat_arr[1]] = [];
							}
							shape_wise_stone_weight_shapes_arr[shape_carat_arr[1]].push(shape_carat_arr[0]);    //['Round':[0.33,0.50,0.60], 'Oval':[0.50] ]
						}
					});
					if (Object.keys(shape_wise_stone_weight_shapes_arr).length > 0) {
						Object.keys(shape_wise_stone_weight_shapes_arr).forEach(function (shape) {
							let mn_c = '', mx_c = '';
							if (shape_wise_stone_weight_shapes_arr[shape][0].includes('-')==true) {
								let shape_carat_arr = shape_wise_stone_weight_shapes_arr[shape][0].split('-');
								mn_c = shape_carat_arr[0];
								mx_c = shape_carat_arr[shape_carat_arr.length - 1];
							} else {
								mn_c = shape_wise_stone_weight_shapes_arr[shape][0];
								mx_c = shape_wise_stone_weight_shapes_arr[shape][shape_wise_stone_weight_shapes_arr[shape].length - 1];
							}
							
							if (center_stone_variance != "") {
								mn_c = parseFloat(mn_c) - parseFloat(center_stone_variance);
								mx_c = parseFloat(mx_c) + parseFloat(center_stone_variance);
							}
							shape_ct_for_api_arr.push(mn_c + '-' + mx_c + ':' + shape);
						});
					} else {
						if (min_carat_weight != "" && max_carat_weight != "") {
							shape_ct_for_api_arr.push(min_carat_weight + '-' + max_carat_weight + ':' + shape_val);
						}
					}
				});
			}
			else {
				//if stone_weight_shapes is not exists then global min-max carat will use
				if (min_carat_weight != "" && max_carat_weight != "") {
					shapes_arr.forEach(function (shape_val, shape_key) {
						shape_ct_for_api_arr.push(min_carat_weight + '-' + max_carat_weight + ':' + shape_val);
					});
				}
			}

			//call api
			var url = '/apps/vdb-maidonna-inventory-app/frontend.php';
			var center_stone_count = "{{attributes_center_stone_count}}";
			var selectedProductType = "MDCST Fixed Center Stone";
			var productType = "{{product.type}}";
			if (productType == 'Pendants') {
				selectedProductType = "MDCST Fixed Pendants";
			} else if (productType == 'Earrings') {
				selectedProductType = "MDCST Fixed Earrings";
			}
			var selectedMatirial = 'LGD';
			if (selected_tab == "gem" && document.getElementsByClassName('center_stone_color_selected_value_2')[0] != null) {
				selectedMatirial = document.getElementsByClassName('center_stone_color_selected_value_2')[0].getAttribute('data-gem_color');
			}

			var selectedQuality = '', selectedQualityArray = [];
			if (selectedMatirial == 'LGD' && document.querySelector('[name="quality"]:checked')) {
				selectedQuality = document.querySelector('[name="quality"]:checked').value;
				selectedQualityArray = selectedQuality.split('-');
			}

			var data = {
				action: 'fetch_dummy_side_stone_products',
				product_type: selectedProductType,
				shop: Shopify.shop, // priceCalculatorObj.shop_domain.value,
				material: selectedMatirial,
				shape_mm: '',
				quality: selectedQuality,
				shape_ct: shape_ct_for_api_arr.join(','),
			};

            if ($xhr_fetch_dummy_side_stone_products_ld != undefined && $xhr_fetch_dummy_side_stone_products_ld != '') {
            	//this is cancel multiple ajax call and consider only last ajax call
             	$xhr_fetch_dummy_side_stone_products_ld.abort();
            }
			$xhr_fetch_dummy_side_stone_products_ld = new XMLHttpRequest();
			$xhr_fetch_dummy_side_stone_products_ld.open("POST", url, true);
			$xhr_fetch_dummy_side_stone_products_ld.responseType = 'json';
			$xhr_fetch_dummy_side_stone_products_ld.setRequestHeader("Content-Type", "application/json");
			$xhr_fetch_dummy_side_stone_products_ld.onreadystatechange = function () {
				if (this.readyState === XMLHttpRequest.DONE && this.status === 200) {
					/*if (document.querySelectorAll('.center_text').length > 0) {
						document.querySelectorAll('.center_text').forEach(function(el) {
							el.style.display = 'inline-block';
						});
					}*/

					if (document.getElementById('first_four_stone_cut_wrapper') != null) {
						document.getElementById('first_four_stone_cut_wrapper').innerHTML = '';
					}

					let resultData = this.response.data;
					if (resultData != undefined && resultData != null && resultData != '') {
						var select = document.getElementById("first_four_stone_cut_wrapper");
						if (document.getElementById("first_four_stone_cut") != null) {
							document.getElementById("first_four_stone_cut").style.display = "block";
						}
						for (const [index, val] of resultData.entries()) {
							var innerDiv = document.createElement('div');

							let optionDisabledWhenDVVS2 = '';
							if(selectedQuality == "D-VVS2" && Number(val.ct) > 5) {
								optionDisabledWhenDVVS2 = 'option--disabled';
							}
							innerDiv.className = 'setting-value-inputs '+ optionDisabledWhenDVVS2;

							var option = document.createElement("input");
							option.type = 'radio'
							option.value = val.ct + 'ct';
							option.className = 'input_value visually-hidden dynamic_stones_from_db';
							option.id = val.ct + 'ct';
							option.name = 'stone';
							option.onclick = function () { setDynamicStones() };
							/* option.text = val.charAt(0).toUpperCase() + val.slice(1); */
							option.text = val.ct + 'ct';
                            if (index == 0 && collection_product_price?.length > 0) {
                                option.checked = true;
                            } else if(selectedCaratWeight === parseFloat(val.ct.trim()).toFixed(2)) {
								{% comment %} if(selectedQuality != "D-VVS2" && Number(val.ct) < 5) {
									option.checked = true;
								} {% endcomment %}
								option.checked = true;
							}
							Object.entries(val).forEach(entry => {
								const [key, value] = entry;
								if (key != 'ctw') {
									if (key == 'variant_price') { // price add for add to cart 
										var newPrice = price_in_shop_currency(value);
										option.setAttribute("data-center_stone_" + key, newPrice);
									} else {
										option.setAttribute("data-center_stone_" + key, value);
									}
									option.setAttribute("data-center_stone_" + key, value);
									if (key == 'variant_price') { // price add for price calculator
										var tempPrice = value * 100;
										var newPrice = price_in_shop_currency(tempPrice);
										option.setAttribute("data-option-price", newPrice);
									}
									if (key == 'image_url') {
										option.setAttribute("data-stone-image", value);
									}
                                    if (key == 'mm') {
										option.setAttribute("data-option-dimension", value);
									}
								}
							});
							if(selectedQualityArray?.length > 0) {
								option.setAttribute("data-option-clarity", selectedQualityArray[1].trim()+' clarity');
								option.setAttribute("data-option-color", selectedQualityArray[0].trim()+' color');
							} else {
								option.setAttribute("data-option-clarity", 'VS clarity');
								option.setAttribute("data-option-color", 'E-F color');
							}
							
							option.setAttribute("data-option-carat", option.value);
							var labelEle = document.createElement('label');
							labelEle.className = 'input_label';
							labelEle.innerHTML = ((productType == 'Earrings') ? (parseFloat(val.ct)*2) : val.ct) + 'ct';
							labelEle.setAttribute("for", val.ct + 'ct');
							innerDiv.appendChild(option);
							innerDiv.appendChild(labelEle);
							select.appendChild(innerDiv);
						}
						if (document.getElementsByClassName('info-border-div')[0] != null && resultData != undefined && resultData != null && resultData != '') {
							document.getElementsByClassName('info-border-div')[0].style.display = 'block';
						}
						var label = document.createElement("label");
					} else {
						if (document.getElementById("first_four_stone_cut") != null) {
