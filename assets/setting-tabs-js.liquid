	/* Change Varinat Option Value And Price */
	function changeVariantOptionAndPrice() {
		if (Shopify.urlParam('variant')) {
			var paramVarinatId = Shopify.urlParam('variant');
			var allVarients = document.getElementById("all_varients");
			if (allVarients != null) {
				for (i = 0; i < allVarients.length; i++) {
					const variantId = allVarients.options[i].value;
					if (variantId == paramVarinatId) {
						const optionDataSetArray = Array.from(allVarients.options[i].getAttributeNames());
						if (optionDataSetArray?.length > 0) {
							for (let dataName of optionDataSetArray) {
								const dataAttributId = dataName.replace('data-','');
								if (dataName.startsWith('data-') && document.querySelector('[data-name-'+dataAttributId+']')) {
									const customOptionElement = document.querySelector('[data-name-'+dataAttributId+']') && document.querySelector('[data-name-'+dataAttributId+']');
									const dataSetName = Object.keys(customOptionElement.dataset)[0].replace('name','').toLocaleLowerCase();
									customOptionElement.value = allVarients.options[i].dataset[dataSetName];

									document.querySelector('[data-text-name-'+dataAttributId+']') && (document.querySelector('[data-text-name-'+dataAttributId+']').innerHTML = "<b>" +allVarients.options[i].dataset[dataSetName] + "</b>");
									varientProductsChangeEvents();
								}
							}
						}
					}
				}
			}
		}
	}
