	function updateOptions(changePosition = 0) {
		let selectedOptions = [];
		let is_custom_change = false;
		optionGroups.forEach(function(optEl, index) {
			var activeOpt = '';
			let optElAlt = optionGroupsAlternate[index];
			if(optEl.getAttribute('data-option-position') == '1'){
				if(optEl.querySelector('input:checked')){
					activeOpt = optEl.querySelector('input:checked').value;
				}
				if(activeOpt == '' && optElAlt){
					if(optElAlt.querySelector('b')){
						activeOpt = optElAlt.querySelector('b').innerHTML.trim();
					}
					else{
						activeOpt = optElAlt.innerHTML.trim();
					}
				}
			}
			else{
				if(optEl.querySelector('.input_label_variant-js.active')){
					activeOpt = optEl.querySelector('.input_label_variant-js.active').getAttribute('data-value');
				}
				if(activeOpt == '' && optElAlt){
					if(optElAlt.querySelector('b')){
						activeOpt = optElAlt.querySelector('b').innerHTML.trim();
					}
					else{
						activeOpt = optElAlt.innerHTML.trim();
					}
				}
			}
			selectedOptions.push(activeOpt);
		});
		const checkNotNull = selectedOptions.filter(opt => opt == '');
		if(checkNotNull.length > 0 || selectedOptions.length == 0) return false;
		const testOptions = [...selectedOptions];
		const checkStatus = variants.filter(variant => {
			return testOptions.every((opt, i) => {
				return !opt || variant.options[i] === opt;
			});
		}).map(opt => opt.available);
		if(typeof checkStatus[0] == 'undefinded' || !checkStatus[0]){
			let available_option = variants.find(variant => variant.available);
			for (let i = 1; i <= 3; i++) {
				var optionSelectedOpt = available_option[`option${i}`];
				if(optionSelectedOpt == null){
					continue;
				}
				if(i == 1){
					if(document.querySelector(`input[name='Metal'][value="${optionSelectedOpt}"]`)){
						document.querySelector(`input[name='Metal'][value="${optionSelectedOpt}"]`).click();
					}
					if(document.getElementById('Metal')){
						document.getElementById('Metal').value = optionSelectedOpt;
					}
				}
				else{
					var optionByPosition = document.querySelector(`[data-check-position="${i}"]`);
					var selectByPosition = document.querySelectorAll(`[data-select-position="${i}"]`);
					if(optionByPosition){
						optionByPosition.value = optionSelectedOpt;
					}
					if(selectByPosition){
						if(document.querySelector(`.active[data-select-position="${i}"]`)){
							document.querySelector(`.active[data-select-position="${i}"]`).classList.remove('active');
						}
						var selectedValueElement = document.querySelector(`[data-select-position="${i}"][data-value="${optionSelectedOpt}"]`);
						if(selectedValueElement){
							selectedValueElement.click();
							selectedValueElement.classList.add('active');
						}
					}
				}
			}
			return false;
		}
		var checkIndex = testOptions.length;
		if(changePosition == 0){
			if(checkIndex == 2){
				changePosition = 1;
				let checkTestOptions = testOptions[1];
			const checkSelectedActiveOptions = variants.filter(variant => variant.options[1] === checkTestOptions)
			.map(opt => {
				return {
					option: opt.option1,
					available: opt.available
				};
			});
			let metalOptionElement = document.querySelectorAll(`[data-select-position='1']`);
			metalOptionElement.forEach(el => {
				var optionValue = el.getAttribute('data-value');
				var elVariant = checkSelectedActiveOptions.filter(val => val.option == optionValue && val.available == true);
				if(elVariant.length > 0){
					if(el.closest('.metal-option-el')){
						el.closest('.metal-option-el').classList.remove('option-disabled');
					}
					el.classList.remove('disabled');
					el.disabled = false;
				}
				else{
					if(el.closest('.metal-option-el')){
						el.closest('.metal-option-el').classList.add('option-disabled');
					}
					el.classList.add('disabled');
					el.disabled = true;
				}
			});
			}
			else if(checkIndex == 3){
				changePosition = 2;
				is_custom_change = true;
			}
		}
		if(changePosition == 1){
			updateOptionGroup("2", (variant, value) => {
				return (
				(!selectedOptions[0] || variant.option1 === selectedOptions[0]) &&
				(!selectedOptions[2] || variant.option3 === selectedOptions[2]) &&
				variant.option2 === value &&
				variant.available
				);
			});
			updateOptionGroup("3", (variant, value) => {
				return (
				(!selectedOptions[0] || variant.option1 === selectedOptions[0]) &&
				(!selectedOptions[1] || variant.option2 === selectedOptions[1]) &&
				variant.option3 === value &&
				variant.available
				);
			});
		}
		if(changePosition == 2){
			updateOptionGroup("1", (variant, value) => {
				return (
				(!selectedOptions[1] || variant.option2 === selectedOptions[1]) &&
				(!selectedOptions[2] || variant.option3 === selectedOptions[2]) &&
				variant.option1 === value &&
				variant.available
				);
			});
			updateOptionGroup("3", (variant, value) => {
				return (
				(!selectedOptions[0] || variant.option1 === selectedOptions[0]) &&
				(!selectedOptions[1] || variant.option2 === selectedOptions[1]) &&
				variant.option3 === value &&
				variant.available
				);
			});
		}
		if(changePosition == 3 || is_custom_change){
			updateOptionGroup("1", (variant, value) => {
				return (
				(!selectedOptions[1] || variant.option2 === selectedOptions[1]) &&
				(!selectedOptions[2] || variant.option3 === selectedOptions[2]) &&
				variant.option1 === value &&
				variant.available
				);
			});
			updateOptionGroup("2", (variant, value) => {
				return (
				(!selectedOptions[0] || variant.option1 === selectedOptions[0]) &&
				(!selectedOptions[2] || variant.option3 === selectedOptions[2]) &&
				variant.option2 === value &&
				variant.available
				);
			});
		}
	}

	function updateOptionGroup(position, conditionFn) {
		let checkOptionElement = document.querySelectorAll(`[data-select-position='${position}']`);
		checkOptionElement.forEach(el => {
			if(position == 1){
				var optionValue = el.getAttribute('data-value');
				var elVariant = variants.some(variant => conditionFn(variant, optionValue));
				if(elVariant){
					if(el.closest('.metal-option-el')){
						el.closest('.metal-option-el').classList.remove('option-disabled');
					}
					el.classList.remove('disabled');
					el.disabled = false;
				}
				else{
					if(el.closest('.metal-option-el')){
						el.closest('.metal-option-el').classList.add('option-disabled');
					}
					el.classList.add('disabled');
					el.disabled = true;
				}
			}
			else{
				var optionValue = el.getAttribute('data-value');
				var elVariant = variants.some(variant => conditionFn(variant, optionValue));
				if(elVariant){
					if(el.closest('.metal-option-el')){
						el.closest('.metal-option-el').classList.remove('option-disabled');
					}
					el.classList.remove('disabled');
					el.disabled = false;
				}
				else{
					if(el.closest('.metal-option-el')){
						el.closest('.metal-option-el').classList.add('option-disabled');
					}
					el.classList.add('disabled');
					el.disabled = true;
				}
			}
		});
	}

