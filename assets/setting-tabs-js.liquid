			if (stone_dimensions_shapes_gems != "") {
				shapes_arr.forEach(function (shape_val) {   //Round Cut
					let shape_wise_stone_dimensions_shapes_gems_arr = [];

					stone_dimensions_shapes_gems = stone_dimensions_shapes_gems.split('.0x').join('x');
					stone_dimensions_shapes_gems = stone_dimensions_shapes_gems.split('.0:').join(':');
					let stone_dimensions_shapes_gems_arr = stone_dimensions_shapes_gems.split('|');   //5.0x5.0:Princess|6.0x6.0:Princess|6.0x6.0:Oval

					let shape_exist_in_dim = 'no';
					stone_dimensions_shapes_gems_arr.forEach(function (sw_val) {
						let shape_dimension_arr = sw_val.split(':'); // ['5.0x5.0','Princess']
						if (shape_dimension_arr[1] != undefined && shape_val.includes(shape_dimension_arr[1])) {
							shape_exist_in_dim = 'yes';
							shape_mm_for_api_arr.push(shape_dimension_arr[0] + ':' + shape_dimension_arr[1]);
						}
