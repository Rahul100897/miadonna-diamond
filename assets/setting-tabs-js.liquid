	function addDaysAndFormat(startDate, daysToAdd, addExtraDay = false) {
		// Validate inputs
		if (isNaN(Date.parse(startDate))) {
			throw new Error("Invalid start date provided.");
		}
		if (typeof daysToAdd !== "number" || daysToAdd < 0) {
			throw new Error("Days to add must be a non-negative number.");
		}

		const daysOfWeek = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
		const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

		// Create a new date object
		const resultDate = new Date(startDate);
		resultDate.setDate(resultDate.getDate() + daysToAdd + (addExtraDay ? 1 : 0)); // Add extra day if specified

		// Format the date
		const dayOfWeek = daysOfWeek[resultDate.getDay()];
		const month = months[resultDate.getMonth()];
		const day = resultDate.getDate();

		return `${dayOfWeek}, ${month} ${day}`;
	}

	function changeShippingDate(ship_date = '') {
		if (Array.from(document.querySelectorAll('.order-ship-date.order-ship-days'))?.length > 0) {
			Array.from(document.querySelectorAll('.order-ship-date.order-ship-days')).forEach(element => element.innerHTML = ship_date?.length > 0 ? ship_date : element.dataset.defaultDate);
		}
	}

    window.addEventListener('resize', function(event) {
        if(window?.innerWidth < 768){
          document.getElementById("customVideoConvention").play();
        } else {
          Array.from(document.getElementsByClassName('video-buttons')) && (Array.from(document.getElementsByClassName('video-buttons')).forEach(e => e.classList.remove('hide')));
        }
    });

	const qualityElements = Array.from(document.getElementsByName('quality')) ?? [];
	if (qualityElements?.length > 0) {
		qualityElements.forEach(function(elem) {
			elem.addEventListener('change', function(e) {
				e.preventDefault();
				center_stone_logic();    
			});
		});	
	}
</script>