	/* Main Add to cart function */
	async function vdb_addtocart(variant_id, quantity = "1", properties = {}) {
		const dateProperty = properties['Estimate Ship Date'];
		let localProperties = JSON.parse(localStorage.getItem('itemProperties')) || {};
		if (!localProperties[variant_id]) {
			localProperties[variant_id] = {};
		}
		localProperties[variant_id]['estimate_ship_date'] = dateProperty;
		if(properties['Length']){
			localProperties[variant_id]['length'] = properties['Length'];
		}

		localStorage.setItem(
			'itemProperties',
			JSON.stringify(localProperties)
		);

		var formData = new FormData();
		formData.append("id", variant_id);
		formData.append("quantity", quantity);
		if (properties['_isMain'] == 'undefined') {
			properties['_isMain'] = '';
		}
		Object.entries(properties).forEach(entry => {
			const [key, value] = entry;
			formData.append("properties[" + key + "]", value);
		});

		let rawResponse = await fetch("/cart/add.js", {
			method: "POST",
			body: formData,
		});
		let cart = await rawResponse.json();
		// /cart/add.js returns the line item on success; on failure (e.g. 422) it
		// returns {status,message,description} with NO `properties`. Guard so a
		// failed add logs instead of throwing on cart.properties (which left the
		// button stuck on "Processing...").
		if (!rawResponse.ok || !cart || !cart.properties) {
			console.log('[combined] /cart/add.js did not succeed', rawResponse.status, cart);
		}
        if (cart && cart.properties && Object.keys(cart).length > 0) {
            let metal = "", stoneShape = "", sideStone = "", centerStone = "", size = "", engravingText = "";
            if (cart.properties['Metal']) {
              metal = cart.properties['Metal'];
            }
            if (cart.properties['Stone Shape']) {
              stoneShape = cart.properties['Stone Shape'];
            }
            if (cart.properties['Side Stone']) {
              sideStone = cart.properties['Side Stone'];
            }
            if (cart.properties['Stone']) {
              centerStone = cart.properties['Stone'];
            }
            if (cart.properties['Size']) {
              size = cart.properties['Size'];
            }
            if (cart.properties['Engraving Text']) {
              engravingText = cart.properties['Engraving Text'];
            }
            dataLayerItemsOnSetting.push({
                item_id: cart.product_id,
                item_name: cart.product_title,
                price: (cart.price/100),
                item_brand: cart.vendor,
                item_category: cart.product_type,
                metal_type: metal,
                stone_shape: stoneShape,
                center_stone: centerStone,
                side_stone: sideStone,
                ring_size: size,
                engraving: engravingText,
                item_variant: cart.variant_title,
                item_list_name: cart.variant_title,
                item_list_id: cart.variant_id,
                quantity: cart.quantity
            });
        }
	}

