	/* Update url parameters logic */
	function updateUrl(url, key, value) {
		if (value !== undefined) {
			value = encodeURI(value);
		}
		var hashIndex = url.indexOf("#") | 0;
		if (hashIndex === -1) hashIndex = url.length | 0;
		var urls = url.substring(0, hashIndex).split("?");
		var baseUrl = urls[0];
		var parameters = "";
		var outPara = {};
		if (urls.length > 1) {
			parameters = urls[1];
		}
		if (parameters !== "") {
			parameters = parameters.split("&");
			for (k in parameters) {
				var keyVal = parameters[k];
				keyVal = keyVal.split("=");
				var ekey = keyVal[0];
				var evalue = "";
				if (keyVal.length > 1) {
					evalue = keyVal[1];
				}
				outPara[ekey] = evalue;
			}
		}

		if (value !== undefined) {
			outPara[key] = value;
		} else {
			delete outPara[key];
		}
		parameters = [];
		for (var k in outPara) {
			parameters.push(k + "=" + outPara[k]);
		}

		var finalUrl = baseUrl;

		if (parameters.length > 0) {
			finalUrl += "?" + parameters.join("&");
		}

		finalUrl = finalUrl + url.substring(hashIndex);
		top.window.history.pushState({}, "", finalUrl);
	}
	/* Update url parameters logic */

    /* Remove url parameters logic */
    function removeParameter(key) {
        // Get the current URL without the hash part
        var urlWithoutHash = window.location.href.split('#')[0];
        
        // Get the query parameters
        var searchParams = new URLSearchParams(window.location.search);
        
        // Remove the parameter
        searchParams.delete(key);
        
        // Construct the new URL
        var newUrl = urlWithoutHash.split('?')[0]; // URL without existing parameters
        if (searchParams.toString() !== '') {
            newUrl += '?' + searchParams.toString(); // Append new parameters if any
        }
        
        // Push the new URL to the browser's history
        window.history.pushState({ path: newUrl }, '', newUrl);
    }
