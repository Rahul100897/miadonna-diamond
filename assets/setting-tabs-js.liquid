						document.querySelector('.product-settings-loader.product-settings-loader-video') && (document.querySelector('.product-settings-loader.product-settings-loader-video').style.display = 'flex');
						checkforVideo();
						checkforVideoLast();// IGS-08-04
					}
				}, 500);
			}
		}
    }
