    function hideShowAddToCartAndInventory() {
		var btn_display = 'atc_btn';
			
		var productType = "{{product.type}}";
		var center_stone_count = parseInt('{{ attributes_center_stone_count }}');
		if(productType=="Engagement Rings" || productType=="Wedding Ring Sets" ){
			// QD combined: a lab diamond attached via ?stone-sku has no Shopify variant id;
			// don't hide Add-to-Cart for it (it's added as a combined Ring+Diamond product).
			var _qdStoneSku = new URLSearchParams(window.location.search).get('stone-sku') || '';
			if (_qdStoneSku == '' && document.getElementById('vdb_stone_variant_id') != null && document.getElementById('vdb_stone_variant_id').value=="") {
				if(center_stone_count>0){
					btn_display = 'stone';
				}
			}
		}

		if (btn_display == 'atc_btn') {
			if (document.getElementById('vdb_add_to_cart') != null) {
				document.getElementById('vdb_add_to_cart').style.display = "block";
			}
			if (document.getElementById('select-your-diamond') != null) {
				document.getElementById('select-your-diamond').style.display = "none";
			}
		} else {
			if (document.getElementById('vdb_add_to_cart') != null) {
				document.getElementById('vdb_add_to_cart').style.display = "none";
			}
			if (document.getElementById('select-your-diamond') != null) {
				document.getElementById('select-your-diamond').style.display = "block";
			}
		}
    }

