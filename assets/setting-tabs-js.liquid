	/* side stone color dropdown selection logic */
	function initSideStoneSelectMenuLi() {
		const sideStoneSelectMenuLi = document.querySelectorAll('.side_Stone_select_li');
		if (sideStoneSelectMenuLi) {
			sideStoneSelectMenuLi.forEach(sideStoneLi => {
				sideStoneLi.addEventListener('click', function () {
					var colorDataset = sideStoneLi.dataset;
					if (colorDataset.sideStoneColor != undefined) {
						// static_side_stone_color_class
						if (colorDataset.sideStoneColor == "Select side Stone") {
							document.getElementById('static_side_stone_color_class').style.display = "none";
						} else {
							document.getElementById('static_side_stone_color_class').style.display = "block";
						}
						document.getElementsByClassName("side_stone_selected_values_2")[0].textContent = colorDataset.sideStoneColor;
						document.getElementsByClassName("side_stone_selected_values")[0].textContent = colorDataset.sideStoneColor;
						document.getElementsByClassName('side_stone_selected_values_2')[0].setAttribute('data-side_stone_color', colorDataset.sideStoneColor)
						document.getElementsByClassName('side_stone_selected_values')[0].setAttribute('data-side_stone_color', colorDataset.sideStoneColor)
						const classNameColor = document.getElementById("sideStoneselectBtn");
						if (classNameColor.classList.length > 1) {
							const lastClass = classNameColor.classList[classNameColor.classList.length - 1];
							classNameColor.classList.remove(lastClass);
						}
						if (colorDataset.sideStoneColorName != '') {
							classNameColor.classList.add(colorDataset.sideStoneColorName);
						}
						var ele = document.querySelector('.side-stone-select-menu');
						ele.classList.toggle('is-open');
						priceCalculatorObj['side_stone_color'] = colorDataset.sideStoneColor;
						updateUrl(window.top.location.href, 'side_stone_color', colorDataset.sideStoneColor);
                        changeImageConvention(colorDataset?.allowImageConvention);
					}
					side_stone_logic();
				});
			});
		}
	}

