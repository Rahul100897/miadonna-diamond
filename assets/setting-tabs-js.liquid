    function isJsonOrString(str) {
        try {
            JSON.parse(str);
        } catch (e) {
            return false;
        }
        return true;
    }
    async function createImageOnFiles(url){
      var formData = new FormData();
      formData.append("action", "create_image_in_files");
      formData.append("shop", Shopify.shop);
      formData.append("image_url", url);
      
      var requestOptions = { method: 'POST', body: formData };
      return fetch("/apps/vdb-maidonna-inventory-app/frontend.php", requestOptions)
      .then(response => response.text())
      .then(result => {
          if (isJsonOrString(result) == true) {
              var resultArray = JSON.parse(result);
              if (resultArray?.status == 'success' && resultArray?.data?.length > 0) {
                return resultArray?.data;
              }
          }
          return '';
      }).catch(error => console.log('error', error));
    }

	/*
	 * QD combined Ring+Diamond add-to-cart.
	 * Creates (or updates) ONE Shopify product = ring + diamond via the qd-app
	 * endpoint (upserts by combined SKU/handle, no duplicates), then adds that
	 * single variant to the cart with both ring and diamond attributes as
	 * line-item properties. Engraving / side stones are still added as their own
	 * grouped line items by the caller (combined_price here is ring + diamond only).
	 */
	async function vdbAddCombinedRingDiamond(opts) {
		console.log('[combined] vdbAddCombinedRingDiamond called', opts);
		var ring = opts.ringProperties || {};
		var qd = opts.qdStone || {};

		// diamond_sku — from the URL (?stone-sku), fall back to the qd-app response.
		var diamondSku = new URLSearchParams(window.location.search).get('stone-sku') || qd.shopify_sku || '';

		// priceCalculatorObj is reset to {} by createPriceCalculator() on every
		// form change, so opts.qdStone can be empty by click time. Re-fetch the
		// diamond from the qd-app API so price + properties are always correct.
		if ((!qd || !qd.price) && diamondSku !== '') {
			try {
				var dRes = await fetch('http://localhost/qd-app/items/' + encodeURIComponent(diamondSku), {
					headers: { 'Authorization': 'Basic ' + btoa('admin:123456') }
				});
				var dJson = await dRes.json();
				if (dJson && dJson.data) { qd = dJson.data; }
			} catch (e) {
				console.log('[combined] diamond refetch failed', e);
			}
		}

		// ring_sku ("Setting SKU") — the selected ring variant's SKU.
		var ringSku = '';
		var ringOpt = document.querySelector('#all_varients option[value="' + opts.ringVariantId + '"]');
		if (ringOpt) { ringSku = ringOpt.getAttribute('data-varient_sku') || ''; }
		if (ringSku === '') { ringSku = '{{ product.selected_or_first_available_variant.sku }}'; }
		if (ringSku === '') { ringSku = '{{ product.handle }}'; }

		// ring_title
		var ringTitleEl = document.getElementById('product_title');
		var ringTitle = (ringTitleEl && ringTitleEl.value) ? ringTitleEl.value : '{{ product.title }}';

		// combined_price = ring (data-final-price is in cents) + diamond (qd price in dollars)
		var ringDollars = parseFloat(opts.ringPriceCents || '0') / 100;
		var diamondDollars = parseFloat(qd.price || '0');
		var combinedPrice = (ringDollars + diamondDollars).toFixed(2);

		// create / upsert the combined product, get its variant id back
		var combinedVariantId = '';
		var combinedReqBody = {
			ring_sku: ringSku,
			diamond_sku: diamondSku,
			ring_title: ringTitle,
			combined_price: combinedPrice,
			ring_image: opts.ringImage || '',
			// Ring product + the SELECTED variant, so the backend clones the
			// ring's metal + spec metafields onto the combined product.
			ring_product_id: "{{ product.id }}",
			ring_variant_id: opts.ringVariantId || ''
		};
		console.log('[combined] POST create-product-by-sku', combinedReqBody);
		try {
			var res = await fetch('http://localhost/qd-app/shopify/create-product-by-sku', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
					'Authorization': 'Basic ' + btoa('admin:123456')
				},
				body: JSON.stringify(combinedReqBody)
			});
			var data = await res.json();
			console.log('[combined] response', res.status, data);
			if (data && data.status === 'success' && data.variant_id) {
				combinedVariantId = data.variant_id;
			} else {
				console.log('[combined] create-product-by-sku failed', data);
			}
		} catch (e) {
			console.log('[combined] create-product-by-sku error (network/CORS/mixed-content?)', e);
		}

		if (!combinedVariantId) {
			// Fail safe: don't add a broken line; reset the button and bail.
			alert('Sorry, we could not add this ring + diamond combination. Please try again.');
			if (document.getElementById('vdb_add_to_cart') != null) {
				document.getElementById('vdb_add_to_cart').innerHTML = "Add To Bag";
				document.getElementById('vdb_add_to_cart').disabled = false;
			}
			return;
		}

		// Merged line-item properties. Start from the ring properties (already carry
		// _groupId, _isMain, Metal, Size, Estimate Ship Date, etc.), then add the
		// diamond. Cert Number is customer-visible; SKUs are "_"-prefixed (admin-only).
		var props = Object.assign({}, ring);
		// Diamond props using the existing order/fulfillment names & formats
		// (matches order #40446: Material, Shape, carat:Xct, color:X color, ...).
		props['Material'] = 'Lab Grown Diamond';
		if (qd.shape)        { props['Shape']       = qd.shape + ' Cut'; }
		if (qd.carat)        { props['carat']       = qd.carat + 'ct'; }
		if (qd.color)        { props['color']       = qd.color + ' color'; }
		if (qd.clarity)      { props['clarity']     = qd.clarity + ' clarity'; }
		if (qd.measurements) { props['Dimension']   = qd.measurements; }
		if (qd.cut)          { props['cut']         = qd.cut; }
		if (qd.lab)          { props['lab']         = qd.lab; }
		if (qd.cert_num)     { props['Cert Number'] = qd.cert_num; }   // customer-visible
		if (qd.shopify_handle) { props['_handle']   = qd.shopify_handle; }
		// admin-only (hidden in cart/checkout, still on the order):
		if (diamondSku)      { props['_diamond_sku']  = diamondSku; }
		if (ringSku)         { props['_setting_sku']  = ringSku; }
		props['_combined_sku'] = ringSku + '-' + diamondSku;
		if (qd.shopify_product_vendor) { props['_vendor_name'] = qd.shopify_product_vendor; }
		if (qd.cert_url)     { props['_cert_url']     = qd.cert_url; }

		await vdb_addtocart(combinedVariantId, '1', props);
	}

