	/* Get nearest class finction */
	function getNearestClass(element, className) {
		const parent = element.parentElement;
		if (!parent) return null; // No parent element to search in

		// Loop through the child elements of the parent(find siblings)
		for (const child of parent.children) {
			if (child !== element && child.classList.contains(className)) {
				return child;
			}
		}
		//if sibling not found, then go to parent element
		element = element.parentElement;
		return getNearestClass(element, className);
	}

