						var video = document.getElementById('customVideoConvention');
						const iconPlayElement = document.querySelector('.video-button-wrapper > .video-buttons #icon-play-btn');
						const iconPauseElement = document.querySelector('.video-button-wrapper > .video-buttons #icon-pause-btn');
