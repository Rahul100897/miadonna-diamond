{% comment %}
  Loose lab-grown diamond detail page.

  Unlike product__loose-lab-diamond.liquid (which reads from a real Shopify
  product), this section renders an empty shell keyed by the ?sku= query
  param. window.LB_GROWN_DIAMOND.initLooseDiamondPage() (lab-created-diamonds.js)
  fetches the diamond from the local qd-app API and fills every placeholder
  below. No Shopify product needs to exist until "Add to Bag" is clicked.
{% endcomment %}

{{ 'section-product.css' | asset_url | stylesheet_tag }}
{{ 'lab-diamonds-filter.css' | asset_url | stylesheet_tag }}
{{ 'certificate-popup.css' | asset_url | stylesheet_tag }}

<noscript>
  {{- 'section-product.css' | asset_url | stylesheet_tag -}}
  {{- 'lab-diamonds-filter.css' | asset_url | stylesheet_tag -}}
  {{- 'certificate-popup.css' | asset_url | stylesheet_tag -}}
</noscript>

{% comment %}
  theme.liquid only loads Fancybox (CSS/JS) when `template contains 'product'`.
  This is a page template, so it's skipped there - load it here instead. The
  gallery below uses data-fancybox="product-gallery", the exact selector
  common.js's Fancybox.bind() targets, so no extra JS init is needed.
{% endcomment %}
{{ 'fancyapps-fancybox.css' | asset_url | stylesheet_tag }}
<script src="{{ 'fancyapps-fancybox.js' | asset_url }}"></script>

{% assign id = section.id %}
{% assign width = section.settings.width | default: 'standard' %}
{% assign padding_top = section.settings.padding_top | default: 40 %}
{% assign padding_bottom = section.settings.padding_bottom | default: 40 %}
{% assign css_class = section.settings.css_class %}

{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }
  #loose-diamond-not-found {
    display: none;
  }
{% endstyle %}

{%- comment -%}
  Ship-by date: identical calculation to loose-diamond-setting-tab.liquid's
  stone-product branch (settings.loose_stone_ship_days), since every diamond
  on this page is a loose stone. Not diamond-specific, so no JS needed.
{%- endcomment -%}
{%- assign holidayDates = settings.holiday_days -%}
{%- assign estimateDays = settings.loose_stone_ship_days -%}
{%- assign estDate = "now" | date: "%s" -%}
{%- assign newestDate = estDate -%}
{%- for i in (1..estimateDays) -%}
  {%- assign newestDate = newestDate | plus: 86400 -%}
  {%- assign estDay = newestDate | date: '%a' -%}
  {%- if estDay == 'Sat' -%}
    {%- assign newestDate = newestDate | plus: 172800 -%}
  {%- endif -%}
  {%- if estDay == 'Sun' -%}
    {%- assign newestDate = newestDate | plus: 86400 -%}
  {%- endif -%}
  {%- assign estDateMonth = newestDate | date: '%d/%m' -%}
  {%- if holidayDates contains estDateMonth -%}
    {%- assign newestDate = newestDate | plus: 86400 -%}
  {%- endif -%}
  {%- assign updated_estDay = newestDate | date: '%a' -%}
  {%- if updated_estDay == 'Sat' -%}
    {%- assign newestDate = newestDate | plus: 172800 -%}
  {%- endif -%}
  {%- if updated_estDay == 'Sun' -%}
    {%- assign newestDate = newestDate | plus: 86400 -%}
  {%- endif -%}
{%- endfor -%}
{%- assign estDay = newestDate | date: '%a' -%}
{%- if estDay == 'Sat' -%}
  {%- assign newestDate = newestDate | date: "%s" | plus: 172800 -%}
{%- endif -%}
{%- if estDay == 'Sun' -%}
  {%- assign newestDate = newestDate | date: "%s" | plus: 86400 -%}
{%- endif -%}
{%- assign estDateMonth = newestDate | date: '%d/%m' -%}
{%- if holidayDates contains estDateMonth -%}
  {%- assign newestDate = newestDate | date: "%s" | plus: 86400 | date: "%a, %b %d, %Y" -%}
  {%- assign estDay = newestDate | date: '%a' -%}
  {%- if estDay == 'Sat' -%}
    {%- assign newestDate = newestDate | date: "%s" | plus: 86400 | date: "%a, %b %d, %Y" -%}
  {%- endif -%}
  {%- if estDay == 'Sun' -%}
    {%- assign newestDate = newestDate | date: "%s" | plus: 172800 | date: "%a, %b %d, %Y" -%}
  {%- endif -%}
{%- endif -%}
{%- assign delivery_date = newestDate -%}

<section class="section {{ css_class }} is-width-{{ width }}" id="loose-diamond-detail-section">
  <div class="container">
    <div class="one-whole column is-flex is-justify-space-between is-align-center">
      <div class="breadcrumb__container">
        <nav class="breadcrumb is-{{ settings.breadcrumb_size | default: 'small' }} is-{{ settings.breadcrumb_capitalization | default: 'uppercase' }}" aria-label="breadcrumbs">
          <ul>
            <li>
              <a href="{{ routes.root_url }}" title="{{ shop.name | escape }}">{{ shop.name | escape }}</a>
            </li>
            <li>
              <span class="breadcrumb-separator"><span class="icon">|</span></span>
              <a href="/collections/loose-lab-grown-diamonds" title="Lab Created Diamond">Lab Created Diamond</a>
            </li>
            <li>
              <span class="breadcrumb-separator"><span class="icon">|</span></span>
              <span id="loose-diamond-breadcrumb-title"></span>
            </li>
          </ul>
        </nav>
      </div>
    </div>
  </div>

  <div id="loose-diamond-not-found" class="container">
    <div class="one-whole column text-center">
      <p>We couldn't find that diamond. It may have sold or the link may be out of date.</p>
      <a class="button button--primary" href="/collections/loose-lab-grown-diamonds">Browse Lab-Grown Diamonds</a>
    </div>
  </div>

  <div id="loose-diamond-detail-wrapper" class="product_section js-product_section container is-justify-space-between has-padding-bottom has-no-side-gutter">
    <div class="product__images three-fifths column large-down--one-whole">
      <div class="pg-container new-loose-diamond" id="loose-diamond-media"></div>
    </div>

    <div class="product__information has-product-sticker two-fifths column large-down--one-whole">
      <div class="sku-review">
        <div class="block--sku">
          <div class="order-ship-date">
            <p class="order-ship-text">SKU:</p>
            <p class="order-ship-date order-ship-sku" id="loose-diamond-sku">-</p>
          </div>
        </div>
      </div>

      <h1 class="product_name title" id="loose-diamond-title"></h1>

      <div class="modal_price subtitle" data-display-savings="false">
        <div class="price-ui">
          <span class="price"><span class="money final_price" id="loose-diamond-price">-</span></span>
        </div>
      </div>

