  document.addEventListener('DOMContentLoaded', function () {
    if (window.LB_GROWN_DIAMOND && window.LB_GROWN_DIAMOND.initLooseDiamondPage) {
      window.LB_GROWN_DIAMOND.initLooseDiamondPage();
    }
  });
</script>

