<script>
  document.addEventListener("DOMContentLoaded", function() {
    console.log('DOM Loaded');
    let loadedPages = localStorage.getItem('loadedPage');
    let currentProduct = localStorage.getItem('currentProduct');
    const pageUrl = new URL(window.location.href);
    const searchParams = new URLSearchParams(pageUrl.search);
  
    // Disable the browser's default scroll restoration
    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }
  
    // Helper function to generate correct page URL
    function getPageUrl(page) {
      const url = new URL(window.location.href);
      url.searchParams.set('page', page);
      return url.toString();
    }
  
    // Load more products
    function loadMoreProducts(url, index) {
      return fetch(url)
        .then(response => response.text())
        .then(data => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(data, 'text/html');
          const thumbnails = doc.querySelectorAll('[data-load-more--grid-item]');
          
          // Convert NodeList to Array and append in sequence
          const thumbnailsArray = Array.from(thumbnails);
          // console.log(index, thumbnailsArray);
          document.querySelector('[data-load-more--grid]').append(...thumbnailsArray);
  
          // Call the swatch function if it exists
          if (typeof onLoadSwatchCollectionSelected == "function") {
            onLoadSwatchCollectionSelected();
          }
        })
        .catch(error => {
          console.error('Error loading products:', error);
        });
    }
  
    // Scroll to the saved position after loading
    function scrollToPosition() {
      if (currentProduct !== null) {
        window.scrollTo(0, currentProduct);
        localStorage.removeItem('currentProduct');
      }
      localStorage.removeItem('loadedPage');
    }
  
    // Sequentially load all pages in order
    if (loadedPages !== null && loadedPages > 1) {
      let loadedPageNumber = parseInt(loadedPages);
  
      (async function loadAllPages() {
        // Load each page sequentially, ensuring correct order
        for (let i = 2; i <= loadedPageNumber; i++) {
          const url = getPageUrl(i);
          console.log(`Loading page ${i}`);
          await loadMoreProducts(url, i);  // Sequentially wait for each fetch to finish
        }
  
        const url2 = getPageUrl(loadedPageNumber + 1);
        console.log('Next page URL:', url2);
        document.querySelector("[data-load-infinite]").setAttribute("href", url2);
  
        // After loading all pages, restore scroll position
        scrollToPosition();
      })();
    }
  
    // Attach click event to product links
    function attachProductLinkClickEvent() {
      document.querySelectorAll('.collection-matrix .product__grid-item a').forEach(function(productLink) {
        productLink.addEventListener('click', function() {
          localStorage.setItem('currentProduct', window.scrollY);
        });
      });
    }
  
    // Initial attach click event
    attachProductLinkClickEvent();
  
    if (currentProduct !== null && loadedPages === null) {
      // If we have a scroll position but no pages loaded, set it immediately
      setTimeout(() => {
        scrollToPosition();
      });
    } else {
      localStorage.removeItem('loadedPage');
    }
  });
</script>
