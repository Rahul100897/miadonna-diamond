  ** Collection template with sidebar **
{% endcomment %}
 {%- capture productHandleContentForQuerystring -%}{{ content_for_header }}{%- endcapture -%}
{%- assign productHandlePageUrl = productHandleContentForQuerystring
  | split: '"pageurl":"'
  | last
  | split: '"'
  | first
  | split: '.myshopify.com'
  | last
  | replace: '\/', '/'
  | replace: '%20', ' '
  | replace: '\u0026', '&'
-%}

{%- assign productHandlePageQueryStringReplace = productHandlePageUrl
  | replace: request.path, ''
  | replace: request.host, ''
-%} 
  {% comment %} {%- capture productHandleContentForQuerystring -%}{{ content_for_header }}{%- endcapture -%}

{%- assign productHandlePageUrl = productHandleContentForQuerystring
  | split: '"pageurl":"'
  | last
  | split: '"'
  | first
  | replace: '\/', '/'
  | replace: '%20', ' '
  | replace: '\u0026', '&'
-%}

{%- assign productHandlePageQueryStringReplace = productHandlePageUrl
  | split: request.path
  | last
-%} {% endcomment %}
{%- assign productHandlePageQueryString = productHandlePageQueryStringReplace | split: '?' | last -%}

