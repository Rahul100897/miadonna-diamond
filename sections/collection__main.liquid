{% assign id = section.id %}
{% comment %}Layout{% endcomment %}
{% assign width = section.settings.width %}
{% assign padding_top = section.settings.padding_top %}
{% assign padding_bottom = section.settings.padding_bottom %}
{% assign animation = section.settings.animation | default: 'none' %}
{% comment %} Advanced {% endcomment %}
{% assign css_class = section.settings.css_class %}
{% assign custom_css = section.settings.custom_css %}

{% comment %} CSS {% endcomment %}
{% style %}
/* div:empty {
  display: none;
} */
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    {% if width == 'wide' %}
      width: 100%;
    {% endif %}
  }

  .sidebar-section {
    {% if section.settings.sidebar_position == 'right' %}
      order: 1;
    {% endif %}
  }

  {% if section.settings.collection_breadcrumb == false %}
    .breadcrumb__container {
      display: none;
    }
  {% endif %}

  {% if section.settings.pagination_type != 'basic_pagination' %}
    .breadcrumb__page-count {
      display: none;
    }
  {% endif %}

  {% if section.settings.collection_tags == false %}
    .collection__tag-filter {
      display: none;
    }
  {% endif %}

  {% if section.settings.collection_sort == false %}
    .collection__sort-by-filter {
      display: none;
    }
  {% endif %}

  {% unless collection.handle contains 'lab-created' or collection.handle == 'solitaire-engagement-rings' %}
    /* .collection__banner .image-element__wrapper {
      max-height: 300px;
      overflow: hidden;
    } */
  {% endunless %}

  /* @media screen and (min-width: 991px) and (max-width: 1500px){
    .section.is-width-wide .collection__banner{
      background-image: url('{{ settings.speedsize_url_pfx_https -}}{{ collection.featured_image | img_url: 'master' }}');
    }
  } */

  {% render 'css-loop',
          css: custom_css,
          id: id
  %}
{% endstyle %}
{% liquid
  assign has_faceted_filtering_block = false
  assign faceted_filtering_blocks_count = section.blocks | where: 'type', 'faceted_filtering' | size
  if faceted_filtering_blocks_count > 0
    assign has_faceted_filtering_block = true
  endif
%}
<section class="section {{ css_class }} {% if template == 'collection.filter-tab' %}is-width-wide{% else %} is-width-{{ width }}{% endif %}" {% if animation != 'none' %}data-scroll-class="{{ animation }}"{% endif %}>
  <div class="collection__banner">
    <div class="container">
      <div class="collection__breadcrumb two-fifths large-down--one-whole column has-padding-bottom">
        {% comment %} Collection breadcrumb {% endcomment %}
        <div class="breadcrumb__container">
          {% render 'breadcrumb', context: 'collection' %}
        </div>
      </div>
    </div>
    <div class="container{% if settings.heading_divider_style == 'long' %} has-heading-divider-below{% endif %}">
      {% comment %}
      <div
        class="image-element__wrapper"
        url="{{ collection.featured_image  }}"
      >
        {% render 'image-element',
          image: collection.featured_image,
          alt: collection.featured_image.alt,
          stretch_width: true,
          section: 'collection-banner',
          focal_point: collection.featured_image.presentation.focal_point
        %}
      </div>
      {% endcomment %}
      <div class="collection__spacer three-fifths large-down--hide column hide-when-banner-enabled hidden"></div>
      <div class="one-third large-down--one-whole column has-no-side-gutter hide-when-banner-enabled heading-container">
        {% comment %} Collection title {% endcomment %}
        {% render 'heading',
          title: collection.title,
          heading_tag: 'h1',
          context: 'collection',
          text_alignment: 'center'
        %}
        {% if collection.description != blank %}
          <div class="collection__description content" tabindex="0">
            {{
              collection.description 
              | replace: 'https:https:', 'https:' | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx 
            }}
          </div>
        {% endif %}
      </div>
      {% if settings.heading_divider_width != 0 and settings.heading_divider_style == 'long' %}
        <div class="heading-divider-below heading-wrapper one-whole column hide-when-banner-enabled">
          <div
            class="
              heading-divider
              heading-divider--{{ settings.heading_divider_style }}
            "
            {% if settings.heading_divider_animation != 'none' %}
              data-scroll-class="{{ settings.heading_divider_animation }}"
            {% endif %}
          ></div>
        </div>
      {% endif %}
    </div>
  </div>
{% if collection.template_suffix != 'design-lab-created-diamonds' %}
{%- render 'lab-created-diamonds-steps' -%}
{% endif %}
  <div class="qdfilterings-section">
    {% if has_faceted_filtering_block and section.settings.show_sidebar == false %}
      {% comment %}
      {% if searchable_setting_collection == 1 or collection.handle == 'shop' or searchable_accessories_collection == 1 %}
      {% endcomment %}
        <div class="collection__faceted-filters collection__filters-top qdfilterings-col">
          {% render 'collection__faceted-filter', collection: collection, hide_results_text: hide_results_text,faceted_filtering: 'true' %}
        </div>  
      {% comment %}
      {% endif %}
      {% endcomment %}
    {% endif %}

    {% if has_faceted_filtering_block and section.settings.show_sidebar == false %}
        {% comment %}
        {% if searchable_setting_collection == 1 or collection.handle == 'shop' or searchable_accessories_collection == 1 %}
        {% endcomment %}
          <div class="contanier-nw qdfilterings-col">
            <div class="collection__faceted-filters-wrapper{% if hide_results_text %} collection__faceted-filters--no-border{% endif %} {{ filter_class }}" style="overflow: visible;">
              <div class="collection__faceted-filters">
                {% render 'collection__faceted-filter', collection: collection, hide_results_text: hide_results_text %}
              </div>
            </div>
          </div>
        {% comment %}
        {% endif %}
        {% endcomment %}
    {% endif %}
  </div>

  {% comment %} Collection description {% endcomment %}
  {% if collection.description != blank %}
    {% comment %}
      <div class="container">
        <div class="one-whole column">
          <div class="collection__description content has-padding-bottom">
            {{ collection.description | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}
          </div>
        </div>
      </div>
    {% endcomment %}
  {% endif %}

  {% if collection.template_suffix == 'design-lab-created-diamonds' %}
    {% render 'collection__content-lab-created-diamonds', productHandlePageQueryString:productHandlePageQueryString %}
  {% else %}
    {% render 'collection__content', productHandlePageQueryString:productHandlePageQueryString  %}
  {% endif %}
</section>
