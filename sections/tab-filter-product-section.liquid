{% comment %}
  ** Collection template with sidebar **
{% endcomment %}
<style>
    .filter-content.price-tab {
      max-width: 50%;
      margin: 1.5rem auto 0rem;
      grid-template-columns: repeat(1,1fr);
    }
    @media (min-width:768){
       #product-append .collection-matrix__wrapper .container {
          grid-template-columns: repeat(4, 1fr) !important;
       }
    }
   #product-append .collection-matrix__wrapper .container .product__thumbnail {
      position: relative;
      margin-bottom: 10px;
      /* background-color: transparent !important; */
  }
   #product-append .collection-matrix__wrapper .container .product__thumbnail .swym-add-to-wishlist-view-product {
      opacity: 1;
      font-size: 22px;
      display: none !important;
  }
   /* #product-append  .section.is-width-wide > .container, #product-append .section.is-width-wide .collection__banner > .container {
      max-width: 100% !important;
      width: 100% !important;
  } */
</style>
{%- assign min_value = 0 -%}
{%- assign max_value = 0 -%}
{%- for filter in collection.filters -%}
  {% if filter.type == 'price_range' %}
    {%- assign min_value = filter.min_value.value | money_without_currency | default: 0 -%}
    {%- assign max_value = filter.max_value.value | money_without_currency | default: filter.range_max -%}
  {%- endif -%}
{%- endfor -%}

{{ faceted_active_filters }}
{% if template.name == 'collection' %}
  {{ 'template-collection.css' | asset_url | stylesheet_tag }}
  {{ 'setting-tabs.css' | asset_url | stylesheet_tag }}

  <noscript>
    {{- 'template-collection.css' | asset_url | stylesheet_tag }}
    {{ 'setting-tabs.css' | asset_url | stylesheet_tag -}}
  </noscript>
{% endif %}

{% assign id = section.id %}
{% comment %}Layout{% endcomment %}
{% assign width = section.settings.width %}
{% assign padding_top = section.settings.padding_top %}
{% assign padding_bottom = section.settings.padding_bottom %}
{% assign animation = section.settings.animation | default: 'none' %}
{% comment %} Advanced {% endcomment %}
{% assign css_class = section.settings.css_class %}
{% assign custom_css = section.settings.custom_css %}

{% comment %} CSS {% endcomment %}
{% style %}
  #shopify-section-{{ id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
    {% if width == 'wide' %}
      width: 100%;
    {% endif %}
  }

  .sidebar-section {
    {% if section.settings.sidebar_position == 'right' %}
      order: 1;
    {% endif %}
  }

  {% if section.settings.collection_breadcrumb == false %}
    .breadcrumb__container {
      display: none;
    }
  {% endif %}

  {% if section.settings.pagination_type != 'basic_pagination' %}
    .breadcrumb__page-count {
      display: none;
    }
  {% endif %}

  {% if section.settings.collection_tags == false %}
    .collection__tag-filter {
      display: none;
    }
  {% endif %}

  {% if section.settings.collection_sort == false %}
    .collection__sort-by-filter {
      display: none;
    }
  {% endif %}

  {% unless collection.handle contains 'lab-created' or collection.handle == 'solitaire-engagement-rings' %}
    .collection__banner .image-element__wrapper {
      max-height: 300px;
      overflow: hidden;
    }
  {% endunless %}

  @media screen and (min-width: 991px) and (max-width: 1500px){
    .section.is-width-wide .collection__banner{
      background-image: url('{{ settings.speedsize_url_pfx_https -}}{{ collection.featured_image | img_url: 'master' }}');
    }
  }

  {% render 'css-loop',
          css: custom_css,
          id: id
  %}
{% endstyle %}

<section
  class="
    section
    {{ css_class }}
    is-width-wide
  "
  {% if animation != 'none' %}
    data-scroll-class="{{ animation }}"
  {% endif %}
>
  {% comment %}
    <div
      class="collection__banner"
    >
      <div class="image-element__wrapper">
        {%
          render 'image-element',
          image: collection.featured_image,
          alt: collection.featured_image.alt,
          stretch_width: true,
          focal_point: collection.featured_image.presentation.focal_point,
        %}
      </div>
      <div class="container {% if settings.heading_divider_style == 'long' %}has-heading-divider-below {% endif %}">
        <div class="collection__breadcrumb two-fifths large-down--one-whole column has-padding-bottom">
          {% comment %} Collection breadcrumb {% endcomment %}
          <div class="breadcrumb__container">
            {% render 'breadcrumb', context: 'collection' %}
          </div>
        </div>
        <div class="collection__spacer three-fifths large-down--hide column hide-when-banner-enabled"></div>
        <div class="four-sixths large-down--one-whole column has-no-side-gutter hide-when-banner-enabled heading-container">
          {% comment %} Collection title {% endcomment %}
          {% render 'heading',
            title: collection.title,
            heading_tag: 'h1',
            context: 'collection',
            text_alignment: 'left'
          %}
          {% if collection.description != blank %}
            <div class="collection__description content">
              {{ collection.description | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}
            </div>
          {% endif %}
        </div>
        {% if settings.heading_divider_width != 0 and settings.heading_divider_style == 'long' %}
          <div class="heading-divider-below heading-wrapper one-whole column hide-when-banner-enabled">
            <div
              class="
                heading-divider
                heading-divider--{{ settings.heading_divider_style }}
              "
              {% if settings.heading_divider_animation != 'none' %}
                data-scroll-class="{{ settings.heading_divider_animation }}"
              {% endif %}
            ></div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endcomment %}

  {% comment %} Collection description {% endcomment %}
  {% if collection.description != blank %}
    {% comment %}
      <div class="container">
        <div class="one-whole column">
          <div class="collection__description content has-padding-bottom">
            {{ collection.description | replace: settings.speedsize_shopify_cdn_url, settings.speedsize_url_pfx_shopify_cdn | replace: settings.speedsize_shop_domain_cdn, settings.speedsize_url_pfx_shop_domain_cdn | replace: settings.speedsize_duplicated_https_search, settings.speedsize_duplicated_https_replacement | replace: settings.speedsize_url_pfx_duplicated, settings.speedsize_url_pfx }}
          </div>
        </div>
      </div>
    {% endcomment %}
  {% endif %}

  {% render 'collection__content' %}
</section>
<script data-theme-editor-load-script src="{{ 'z__jsSidebar.js' | asset_url }}"></script>
<script src="{{ 'z__jsCollection.js' | asset_url }}"></script>
